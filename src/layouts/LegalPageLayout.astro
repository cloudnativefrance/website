---
import Layout from "./Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import type { Locale } from "@/i18n/ui";

interface Props {
  title: string;
  lastUpdated: string; // "2026-04-12"
  description: string;
  lang?: string;
}

const { title, lastUpdated, description, lang } = Astro.props;
const resolvedLang = (lang ?? getLangFromUrl(Astro.url)) as Locale;
const t = useTranslations(resolvedLang);
const lastUpdatedLine = t("legal.last_updated").replace("{date}", lastUpdated);
---
<Layout title={title} description={description} lang={resolvedLang}>
  <main class="mx-auto max-w-prose px-4 py-16">
    <h1 class="text-4xl font-bold leading-tight text-foreground">{title}</h1>
    <p class="text-sm text-muted-foreground mt-2">{lastUpdatedLine}</p>
    <div class="mt-8 text-foreground">
      <slot />
    </div>
  </main>
</Layout>
