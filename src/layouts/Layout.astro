---
import { Font } from "astro:assets";
import "../styles/global.css";
import LanguageToggle from "@/components/LanguageToggle.astro";

interface Props {
  title?: string;
  lang?: string;
}

const { title = "Cloud Native Days France 2027", lang } = Astro.props;
const resolvedLang = lang ?? Astro.currentLocale ?? "fr";
---
<html lang={resolvedLang} class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <Font cssVariable="--font-dm-sans" preload />
  </head>
  <body class="bg-background text-foreground font-sans antialiased min-h-screen">
    <header class="sticky top-0 z-50 flex items-center justify-end px-4 py-3 backdrop-blur-sm bg-background/90">
      <LanguageToggle />
    </header>
    <slot />
  </body>
</html>
