---
import Layout from "../layouts/Layout.astro";
import GeoBackground from "@/components/patterns/GeoBackground.astro";
import { Button } from "@/components/ui/button";
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Separator } from "@/components/ui/separator";
---

<Layout title="Cloud Native Days France 2027 — Design System Preview">
  <main>
    {/* ── Hero Section ─────────────────────────────────────── */}
    <section class="relative flex min-h-[80vh] lg:min-h-screen flex-col items-center justify-center overflow-hidden px-4 py-20 text-center">
      <GeoBackground class="absolute inset-0" />
      <div class="relative z-10 mx-auto flex max-w-4xl flex-col items-center gap-6">
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl" style="line-height:1.05; letter-spacing:-0.02em;">
          Cloud Native Days France
        </h1>
        <p class="max-w-2xl text-lg text-muted-foreground sm:text-xl" style="line-height:1.4;">
          June 3, 2027 &mdash; CENTQUATRE-PARIS (104)
        </p>

        {/* CTA Buttons */}
        <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:gap-4">
          <Button client:idle size="lg" className="h-[52px] px-8 text-lg font-medium shadow-[0_0_20px_oklch(62.5%_0.162_259.9_/_0.3)] hover:translate-y-[-1px] transition-all duration-150">
            Get Your Ticket
          </Button>
          <Button client:idle variant="outline" size="lg" className="h-[52px] px-8 text-lg font-medium">
            View Schedule
          </Button>
        </div>
      </div>
    </section>

    <Separator client:idle className="mx-auto max-w-5xl" />

    {/* ── Stats Cards Section ──────────────────────────────── */}
    <section class="mx-auto max-w-5xl px-4 py-16 lg:py-24">
      <h2 class="mb-10 text-center text-3xl font-bold tracking-tight sm:text-4xl" style="letter-spacing:-0.02em;">
        The Event in Numbers
      </h2>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <Card client:idle className="border-border transition-colors duration-200 hover:border-primary/50">
          <CardHeader>
            <CardTitle className="text-lg font-semibold">50+ Talks</CardTitle>
            <CardDescription>Deep dives, lightning talks, and workshops across multiple tracks</CardDescription>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">From Kubernetes internals to platform engineering best practices</p>
          </CardContent>
        </Card>

        <Card client:idle className="border-border transition-colors duration-200 hover:border-primary/50">
          <CardHeader>
            <CardTitle className="text-lg font-semibold">1700+ Attendees</CardTitle>
            <CardDescription>The largest cloud-native community gathering in France</CardDescription>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">Engineers, architects, and decision-makers from across Europe</p>
          </CardContent>
        </Card>

        <Card client:idle className="border-border transition-colors duration-200 hover:border-primary/50">
          <CardHeader>
            <CardTitle className="text-lg font-semibold">40+ Partners</CardTitle>
            <CardDescription>Industry leaders and innovative startups supporting the event</CardDescription>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">Platinum, Gold, Silver, and Community sponsors</p>
          </CardContent>
        </Card>
      </div>
    </section>

    <Separator client:idle className="mx-auto max-w-5xl" />

    {/* ── Badges Section ───────────────────────────────────── */}
    <section class="mx-auto max-w-5xl px-4 py-16 lg:py-24">
      <h2 class="mb-6 text-center text-3xl font-bold tracking-tight sm:text-4xl" style="letter-spacing:-0.02em;">
        Conference Tracks
      </h2>
      <p class="mb-8 text-center text-muted-foreground">Explore sessions across our curated tracks</p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <Badge client:idle className="bg-primary/15 text-primary px-3 py-1 text-xs font-medium uppercase tracking-widest rounded-full">Kubernetes</Badge>
        <Badge client:idle variant="secondary" className="bg-accent/15 text-accent px-3 py-1 text-xs font-medium uppercase tracking-widest rounded-full">Platform Engineering</Badge>
        <Badge client:idle variant="secondary" className="bg-chart-4/15 text-chart-4 px-3 py-1 text-xs font-medium uppercase tracking-widest rounded-full">Observability</Badge>
        <Badge client:idle variant="secondary" className="bg-destructive/15 text-destructive px-3 py-1 text-xs font-medium uppercase tracking-widest rounded-full">Security</Badge>
      </div>
    </section>

    <Separator client:idle className="mx-auto max-w-5xl" />

    {/* ── Typography Showcase ──────────────────────────────── */}
    <section class="mx-auto max-w-5xl px-4 py-16 lg:py-24">
      <h2 class="mb-10 text-center text-3xl font-bold tracking-tight sm:text-4xl" style="letter-spacing:-0.02em;">
        Typography Scale
      </h2>
      <div class="space-y-6">
        <div>
          <p class="mb-1 text-xs uppercase tracking-widest text-muted-foreground">h1 &mdash; text-6xl / 64px / Bold</p>
          <h1 class="text-6xl font-bold" style="line-height:1.05; letter-spacing:-0.02em;">Heading One</h1>
        </div>
        <div>
          <p class="mb-1 text-xs uppercase tracking-widest text-muted-foreground">h2 &mdash; text-4xl / 36px / Bold</p>
          <h2 class="text-4xl font-bold" style="line-height:1.2; letter-spacing:-0.02em;">Heading Two</h2>
        </div>
        <div>
          <p class="mb-1 text-xs uppercase tracking-widest text-muted-foreground">h3 &mdash; text-3xl / 30px / SemiBold</p>
          <h3 class="text-3xl font-semibold" style="line-height:1.3; letter-spacing:-0.01em;">Heading Three</h3>
        </div>
        <div>
          <p class="mb-1 text-xs uppercase tracking-widest text-muted-foreground">Body &mdash; text-base / 16px / Regular</p>
          <p class="text-base" style="line-height:1.6;">Cloud Native Days France brings together the brightest minds in cloud-native technology for a full day of learning, networking, and community building.</p>
        </div>
        <div>
          <p class="mb-1 text-xs uppercase tracking-widest text-muted-foreground">Muted &mdash; text-sm / 14px / Regular</p>
          <p class="text-sm text-muted-foreground" style="line-height:1.5;">Secondary text and captions appear in muted-foreground for clear visual hierarchy.</p>
        </div>
      </div>
    </section>
  </main>
</Layout>
