---
import Layout from "../layouts/Layout.astro";
import HeroSection from "@/components/hero/HeroSection.astro";
import KeyNumbers from "@/components/hero/KeyNumbers";
import CfpSection from "@/components/cfp/CfpSection.astro";
import PastEditionSection from "@/components/past-editions/PastEditionSection.astro";
import PastEditionMinimal from "@/components/past-editions/PastEditionMinimal.astro";
import TestimonialsStrip from "@/components/testimonials/TestimonialsStrip.astro";
import { EDITION_2026, EDITION_2023 } from "@/lib/editions-data";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { eventSchemaJson } from "@/lib/event-schema";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const description = t("seo.default_description");
const siteUrl = Astro.site ? Astro.site.toString() : "https://cloudnativedays.fr/";
const schemaJson = eventSchemaJson({ lang, siteUrl, description });

// 2026-variant props — real recap content (ported from venue/index.astro)
const edition2026Props = {
  rail: t("editions.rail.2026"),
  heading: t("editions.2026.heading"),
  stats: EDITION_2026.stats.map((s) => ({ value: s.value, label: t(s.labelKey) })),
  video: {
    youtubeId: EDITION_2026.youtubeId,
    caption: t("editions.2026.video_caption"),
  },
  photos: EDITION_2026.thumbnails.map((th) => ({
    src: th.src,
    alt: t(th.altKey),
    size: th.size,
  })),
  galleryCta: {
    label: t("editions.2026.gallery_cta") || t("editions.2023.gallery_cta"),
    href: EDITION_2026.galleryUrl,
  },
  placeholder: EDITION_2026.placeholder,
  id: "edition-2026",
};

// 2023-variant props — minimal homepage block (17-04): 3 photos + logo + playlist link
const edition2023MinimalProps = {
  id: "edition-2023",
  title: t("editions.2023.compact_title"),
  photos: EDITION_2023.thumbnails.map((th) => ({
    src: th.src,
    alt: t(th.altKey),
  })),
  logo: EDITION_2023.brandLogo,
  logoAlt: "Kubernetes Community Days France 2023",
  playlistLink: {
    label: t("editions.2023.video_cta"),
    href: EDITION_2023.playlistUrl,
  },
};
---

<Layout
  title={t("site.title")}
  description={description}
  ogType="event"
>
  <script type="application/ld+json" set:html={schemaJson} />
  <main>
    <HeroSection />
    <KeyNumbers client:idle lang={lang} />
    <CfpSection />
    <TestimonialsStrip />
    <PastEditionSection {...edition2026Props} />
    <PastEditionMinimal {...edition2023MinimalProps} />
  </main>
</Layout>
