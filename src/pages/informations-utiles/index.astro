---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const VENUE = {
  name: "CENTQUATRE-PARIS",
  address: "5 rue Curial, 75019 Paris",
  website: "https://www.104.fr",
  // lat/lon used for the OpenStreetMap iframe + marker
  lat: 48.8899,
  lon: 2.3702,
};
const bbox = `${VENUE.lon - 0.006},${VENUE.lat - 0.0035},${VENUE.lon + 0.006},${VENUE.lat + 0.0035}`;
const mapSrc = `https://www.openstreetmap.org/export/embed.html?bbox=${bbox}&layer=mapnik&marker=${VENUE.lat},${VENUE.lon}`;
const mapLink = `https://www.openstreetmap.org/?mlat=${VENUE.lat}&mlon=${VENUE.lon}#map=17/${VENUE.lat}/${VENUE.lon}`;

type TransportEntry = {
  key: "metro" | "rer" | "bus" | "car";
  label: string;
  // Either a single station (main+detail) or multiple stations stacked.
  stations?: Array<{ name: string; time: string }>;
  main?: string;
  detail?: string;
};

const transport: TransportEntry[] = [
  {
    key: "metro",
    label: t("venue.transport.metro"),
    stations: [
      { name: t("venue.transport.metro_riquet"),     time: t("venue.transport.metro_riquet_time") },
      { name: t("venue.transport.metro_stalingrad"), time: t("venue.transport.metro_stalingrad_time") },
    ],
  },
  {
    key: "rer",
    label: t("venue.transport.rer"),
    main: "Rosa Parks — RER E",
    detail: t("venue.transport.rer_detail"),
  },
  {
    key: "bus",
    label: t("venue.transport.bus"),
    main: "54, 60, 150, 239",
    detail: t("venue.transport.bus_detail"),
  },
  {
    key: "car",
    label: t("venue.transport.car"),
    main: t("venue.transport.car_main"),
    detail: t("venue.transport.car_detail"),
  },
];

const accessibility = [
  t("venue.access.pmr"),
  t("venue.access.elevators"),
  t("venue.access.toilets"),
  t("venue.access.guide_dogs"),
];
---

<Layout title={`${t("venue.heading")} | ${t("site.title")}`}>
  <main class="px-4 md:px-6 lg:px-8">
    <!-- 1. Hero -->
    <section class="max-w-6xl mx-auto pt-16 md:pt-24 pb-10">
      <p class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-primary, #4985e8);">
        {t("venue.rail_label")}
      </p>
      <h1 class="mt-3 text-4xl md:text-5xl font-bold text-foreground tracking-tight" style="letter-spacing:-0.02em;">
        {VENUE.name}
      </h1>
      <p class="mt-2 text-lg text-muted-foreground">{VENUE.address}</p>
      <p class="mt-3 text-sm text-muted-foreground">
        <span>{t("venue.event_date")}</span>
        <span class="mx-2">·</span>
        <span>{t("venue.event_hours")}</span>
      </p>
    </section>

    <!-- 2. Venue description + map -->
    <section class="max-w-6xl mx-auto pb-16 md:pb-20 grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
      <div class="flex flex-col justify-center">
        <p class="text-lg text-foreground" style="line-height:1.6;">
          {t("venue.description")}
        </p>
        <p class="mt-6">
          <a
            href={VENUE.website}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 text-sm font-medium text-primary hover:underline"
          >
            {t("venue.website_cta")} <span aria-hidden="true">→</span>
          </a>
        </p>
      </div>

      <div class="rounded-xl overflow-hidden border border-border bg-card">
        <iframe
          src={mapSrc}
          title={`Carte de ${VENUE.name} - OpenStreetMap`}
          loading="lazy"
          class="w-full aspect-[16/10] border-0"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
        <div class="flex items-center justify-between px-4 py-2 text-xs text-muted-foreground">
          <a href={mapLink} target="_blank" rel="noopener noreferrer" class="hover:text-foreground">
            {t("venue.map_larger")} →
          </a>
          <span>© OpenStreetMap contributors</span>
        </div>
      </div>
    </section>

    <!-- 3. Transport -->
    <section class="max-w-6xl mx-auto pb-16 md:pb-20">
      <p class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-primary, #4985e8);">
        {t("venue.transport.rail_label")}
      </p>
      <h2 class="mt-3 mb-8 text-3xl font-bold text-foreground tracking-tight" style="letter-spacing:-0.02em;">
        {t("venue.transport.heading")}
      </h2>

      <ul role="list" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {transport.map(({ key, label, stations, main, detail }) => (
          <li class="rounded-xl border border-border bg-card p-6">
            <div class="flex items-start gap-4">
              <span class="flex shrink-0 h-10 w-10 items-center justify-center rounded-full bg-primary/10">
                {key === "metro" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><circle cx="12" cy="12" r="9"/><path d="M6 15l1.5-6L12 14l4.5-5L18 15"/></svg>
                )}
                {key === "rer" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><rect x="4" y="3" width="16" height="15" rx="2"/><path d="M4 11h16"/><circle cx="8" cy="14.5" r="1"/><circle cx="16" cy="14.5" r="1"/><path d="M8 18l-2 3"/><path d="M16 18l2 3"/></svg>
                )}
                {key === "bus" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M4 6v11a2 2 0 002 2h12a2 2 0 002-2V6"/><path d="M4 10h16"/><circle cx="8" cy="17" r="1"/><circle cx="16" cy="17" r="1"/><path d="M6 6V5a2 2 0 012-2h8a2 2 0 012 2v1"/></svg>
                )}
                {key === "car" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M3 13l2-6a2 2 0 012-2h10a2 2 0 012 2l2 6"/><path d="M3 13v5a1 1 0 001 1h2a1 1 0 001-1v-1h10v1a1 1 0 001 1h2a1 1 0 001-1v-5"/><circle cx="7.5" cy="15" r="1"/><circle cx="16.5" cy="15" r="1"/></svg>
                )}
              </span>
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">{label}</p>
                {stations ? (
                  <ul role="list" class="mt-1 space-y-1">
                    {stations.map((s) => (
                      <li class="flex flex-wrap items-baseline gap-x-2">
                        <span class="text-base font-semibold text-foreground">{s.name}</span>
                        <span class="text-xs text-muted-foreground">{s.time}</span>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <>
                    <p class="mt-1 text-base font-semibold text-foreground">{main}</p>
                    <p class="mt-1 text-sm text-muted-foreground">{detail}</p>
                  </>
                )}
              </div>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <!-- 4. Accessibility -->
    <section class="max-w-6xl mx-auto pb-16 md:pb-20">
      <p class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-primary, #4985e8);">
        {t("venue.access.rail_label")}
      </p>
      <h2 class="mt-3 mb-6 text-3xl font-bold text-foreground tracking-tight" style="letter-spacing:-0.02em;">
        {t("venue.access.heading")}
      </h2>
      <ul role="list" class="flex flex-wrap gap-3">
        {accessibility.map((label) => (
          <li class="inline-flex items-center gap-2 rounded-full border border-border bg-card px-4 py-2 text-sm text-foreground">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
              <path d="M5 12l5 5L20 7"/>
            </svg>
            {label}
          </li>
        ))}
      </ul>
      <p class="mt-4 text-sm text-muted-foreground">
        {t("venue.access.note")}
      </p>
    </section>
  </main>
</Layout>
