---
import Layout from "../../layouts/Layout.astro";
import HeroSection from "@/components/hero/HeroSection.astro";
import KeyNumbers from "@/components/hero/KeyNumbers";
import Edition2026Combined from "@/components/past-editions/Edition2026Combined.astro";
import SponsorsPlatinumStrip from "@/components/sponsors/SponsorsPlatinumStrip.astro";
import { getCollection } from "astro:content";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { eventSchemaJson } from "@/lib/event-schema";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const description = t("seo.default_description");
const siteUrl = Astro.site ? Astro.site.toString() : "https://cloudnativedays.fr/";
const schemaJson = eventSchemaJson({ lang, siteUrl, description });

// Sponsors loaded at the page boundary — CSV is the single source of truth (CLAUDE.md).
// SponsorsPlatinumStrip is data-agnostic by design (Phase 24 decision); the page filter
// keeps tier-selection logic out of the reusable component.
const allSponsors = await getCollection("sponsors");
const platinumSponsors = allSponsors.filter((s) => s.data.tier === "platinum");
---

<Layout
  title={t("site.title")}
  description={description}
  ogType="event"
>
  <script type="application/ld+json" set:html={schemaJson} />
  <main>
    <HeroSection />
    <KeyNumbers client:idle lang={lang} />
    <Edition2026Combined />
    {platinumSponsors.length > 0 && (
      <SponsorsPlatinumStrip
        id="sponsors-homepage"
        sponsors={platinumSponsors}
        lang={lang}
      />
    )}
  </main>
</Layout>
