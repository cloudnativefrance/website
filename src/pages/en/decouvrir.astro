---
import Layout from "@/layouts/Layout.astro";
import { useTranslations } from "@/i18n/utils";

const lang = "en";
const t = useTranslations(lang);
---

<Layout title={t("about.subnav.discover")} description="Discover Cloud Native Days France." lang={lang}>
  <main class="mx-auto max-w-3xl px-4 md:px-6 py-24 md:py-32 text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-muted-foreground">
      {t("nav.home")}
    </p>
    <h1 class="mt-3 text-4xl md:text-5xl font-bold text-foreground tracking-tight" style="letter-spacing:-0.02em;">
      {t("about.subnav.discover")}
    </h1>
    <p class="mt-6 text-base md:text-lg text-muted-foreground">
      {t("about.page.placeholder")}
    </p>
  </main>
</Layout>
