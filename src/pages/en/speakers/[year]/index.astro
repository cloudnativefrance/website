---
import Layout from "../../../../layouts/Layout.astro";
import SpeakerAvatar from "@/components/speakers/SpeakerAvatar.astro";
import { getSpeakersByLocale, getSlug, getPrimaryTalk } from "@/lib/speakers";
import { loadSessions, type SessionRow } from "@/lib/schedule";
import { getLangFromUrl, useTranslations, getLocalePath } from "@/i18n/utils";
import { EDITIONS, isEdition, CURRENT_EDITION, type Edition } from "@/lib/editions";
import ComingNotice from "@/components/ComingNotice.astro";

export async function getStaticPaths() {
  return EDITIONS.map((year) => ({ params: { year: String(year) } }));
}

const { year: yearParam } = Astro.params;
const yearNum = Number(yearParam);
if (!isEdition(yearNum)) {
  return Astro.redirect(`/en/speakers/${CURRENT_EDITION}`, 308);
}
const year: Edition = yearNum;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const speakers = await getSpeakersByLocale(lang, year);
const sessions = await loadSessions(year);
const primaryTalkBySlug = new Map<string, SessionRow>();
for (const speaker of speakers) {
  const primary = getPrimaryTalk(getSlug(speaker.id), sessions);
  if (primary) primaryTalkBySlug.set(getSlug(speaker.id), primary);
}
const keynote = speakers.find((s) => s.data.keynote);
const regular = speakers
  .filter((s) => !s.data.keynote)
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<Layout title={`${t("speakers.heading")} ${year} | ${t("site.title")}`}>
  <main class="px-4 md:px-6 lg:px-8">
    {year === CURRENT_EDITION && <ComingNotice class="mx-auto max-w-6xl mt-8" />}
    <section class="pt-16 md:pt-24 pb-10 md:pb-14 text-center">
      <h1
        class="text-4xl md:text-5xl font-bold text-foreground tracking-tight"
        style="letter-spacing: -0.02em;"
      >
        {`${t("speakers.heading")} ${year}`}
      </h1>
      <p class="mt-3 text-base md:text-lg text-muted-foreground">
        {t("speakers.subtext")}
      </p>
    </section>

    {speakers.length === 0 && (
      <section class="text-center py-16">
        <h2 class="text-2xl font-bold text-foreground">
          {t("speakers.empty_heading")}
        </h2>
        <p class="mt-2 text-muted-foreground">{t("speakers.empty_body")}</p>
      </section>
    )}

    {keynote && (
      <section class="max-w-6xl mx-auto pb-14 md:pb-20">
        <p
          class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-accent"
        >
          {t("speakers.keynote_rail_label")}
        </p>

        <a
          href={getLocalePath(lang, `/speakers/${year}/${getSlug(keynote.id)}`)}
          class="group relative flex flex-col md:flex-row items-center gap-8 md:gap-10 rounded-2xl border border-border bg-card p-8 md:p-10 overflow-hidden transition-colors duration-200 hover:border-primary/50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
        >
          <!-- Subtle blue glow behind the photo -->
          <span
            aria-hidden="true"
            class="pointer-events-none absolute -left-24 top-1/2 -translate-y-1/2 h-[280px] w-[280px] rounded-full bg-primary/10 blur-3xl"
          ></span>

          <!-- Photo with pink accent ring -->
          <div class="relative z-10 shrink-0">
            <span
              aria-hidden="true"
              class="absolute -inset-1 rounded-full ring-2 ring-accent/70"
            ></span>
            <div class="relative rounded-full overflow-hidden h-[180px] w-[180px] md:h-[220px] md:w-[220px] bg-secondary">
              <SpeakerAvatar
                name={keynote.data.name}
                photo={keynote.data.photo_url}
                size="lg"
              />
            </div>
          </div>

          <!-- Info -->
          <div class="relative z-10 flex-1 text-center md:text-left">
            <span
              class="inline-block mb-3 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-accent bg-accent/15 rounded-full"
            >
              {t("speakers.keynote_badge")}
            </span>
            <h2
              class="text-2xl md:text-4xl font-bold text-foreground"
              style="letter-spacing: -0.02em;"
            >
              {keynote.data.name}
            </h2>
            {(keynote.data.role || keynote.data.company) && (
              <p class="mt-1 text-base text-muted-foreground">
                {[keynote.data.role, keynote.data.company]
                  .filter(Boolean)
                  .join(" — ")}
              </p>
            )}
            {(() => {
              const primary = primaryTalkBySlug.get(getSlug(keynote.id));
              return primary && (
                <>
                  <p class="mt-5 text-lg md:text-xl text-foreground italic">
                    "{primary.title}"
                  </p>
                  <p class="mt-3 text-sm text-muted-foreground">
                    <span>{primary.durationMin} min</span>
                    {primary.track && (
                      <>
                        <span class="mx-2">·</span>
                        <span>{t("speakers.track_prefix")} {primary.track}</span>
                      </>
                    )}
                  </p>
                </>
              );
            })()}
            <span
              class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-primary group-hover:underline"
            >
              {t("speakers.view_profile")} <span aria-hidden="true">→</span>
            </span>
          </div>
        </a>
      </section>
    )}

    {regular.length > 0 && (
      <section class="max-w-7xl mx-auto pb-16 md:pb-24">
        <p
          class="mb-4 text-xs font-semibold uppercase tracking-[0.2em]"
          style="color: var(--color-primary, #4985e8);"
        >
          {t("speakers.regular_rail_label")}
        </p>

        <ul
          role="list"
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 md:gap-5"
        >
          {regular.map((speaker) => (
            <li>
              <a
                href={getLocalePath(lang, `/speakers/${year}/${getSlug(speaker.id)}`)}
                class="group block h-full rounded-lg border border-border bg-card p-5 text-center transition-all duration-200 hover:border-primary/60 motion-safe:hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
              >
                <div class="flex flex-col items-center">
                  <SpeakerAvatar
                    name={speaker.data.name}
                    photo={speaker.data.photo_url}
                    size="sm"
                  />
                  <p class="mt-3 text-base font-bold text-foreground">
                    {speaker.data.name}
                  </p>
                  {(speaker.data.role || speaker.data.company) && (
                    <p class="mt-1 text-sm text-muted-foreground">
                      {[speaker.data.role, speaker.data.company]
                        .filter(Boolean)
                        .join(" — ")}
                    </p>
                  )}
                  {(() => {
                    const primary = primaryTalkBySlug.get(getSlug(speaker.id));
                    return primary && (
                      <p class="mt-2 text-[13px] text-muted-foreground line-clamp-2">
                        {primary.title}
                      </p>
                    );
                  })()}
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </main>
</Layout>
