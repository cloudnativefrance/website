---
import Layout from "../../layouts/Layout.astro";
import ScheduleGrid from "@/components/schedule/ScheduleGrid.astro";
import { loadSessions } from "@/lib/schedule";
import { getSpeakersByLocale, getSlug } from "@/lib/speakers";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import ComingSoonLayout from "@/components/flags/ComingSoonLayout.astro";
import { isFlagActive } from "@/lib/flags";
import { EDITIONS, isEdition, CURRENT_EDITION, type Edition } from "@/lib/editions";
import ComingNotice from "@/components/ComingNotice.astro";
import { ui } from "@/i18n/ui";

export async function getStaticPaths() {
  return EDITIONS.map((year) => ({ params: { year: String(year) } }));
}

const { year: yearParam } = Astro.params;
const yearNum = Number(yearParam);
if (!isEdition(yearNum)) {
  return Astro.redirect(`/programme/${CURRENT_EDITION}`, 308);
}
const year: Edition = yearNum;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const sessions = await loadSessions(year);
const speakerEntries = await getSpeakersByLocale(lang, year);

// Build a lookup map keyed by BOTH slug and full name so that sessions.csv
// rows referring to a speaker either way resolve to the same record. Each
// value carries the canonical display name + (optional) company so the
// schedule cards can render "Name (Company)" without extra fetching.
const speakerInfo = new Map<string, { name: string; company?: string }>();
for (const s of speakerEntries) {
  const info = { name: s.data.name, company: s.data.company };
  speakerInfo.set(getSlug(s.id), info);
  speakerInfo.set(s.data.name, info);
}

// Year-specific rail label (e.g. "Programme — 03 Février 2026") with fallback
// to the generic 2027 label.
const yearKey = `schedule.rail_label.${year}`;
const railLabel =
  (ui[lang] as Record<string, string>)[yearKey] ??
  (ui.fr as Record<string, string>)[yearKey] ??
  t("schedule.rail_label");

// Future editions (year > CURRENT_EDITION) stay behind the `programme` flag.
// Past/current editions always render — 2026 has real archive data, 2023 etc.
// fall through to the empty-state until their Sheet tab lands.
const isUpcomingEdition = year > CURRENT_EDITION;
const programmeReady = !isUpcomingEdition || isFlagActive("programme");
---

{programmeReady ? (
<Layout title={`${t("schedule.heading")} ${year} | ${t("site.title")}`}>
    <main
      class="px-4 md:px-6 lg:px-8"
      data-schedule-active-singular={t("schedule.filter.active_singular")}
      data-schedule-active-plural={t("schedule.filter.active_plural")}
    >
      {sessions.length === 0 ? (
        <section class="max-w-3xl mx-auto pt-16 md:pt-24 pb-20 text-center">
          <p
            class="text-xs font-semibold uppercase tracking-[0.2em]"
            style="color: var(--color-primary, #4985e8);"
          >
            {railLabel}
          </p>
          <h1 class="mt-3 text-4xl md:text-5xl font-bold text-foreground tracking-tight" style="letter-spacing:-0.02em;">
            {`${t("schedule.heading")} ${year}`}
          </h1>
          <p class="mt-6 text-base md:text-lg text-muted-foreground">
            {t("schedule.empty_state")}
          </p>
        </section>
      ) : (
        <>
          <section class="max-w-7xl mx-auto pt-16 md:pt-20 pb-6">
            {year === CURRENT_EDITION && <ComingNotice class="mb-8" />}
            <p
              class="text-xs font-semibold uppercase tracking-[0.2em]"
              style="color: var(--color-primary, #4985e8);"
            >
              {t("schedule.rail_label")}
            </p>
            <h1 class="mt-3 text-4xl md:text-5xl font-bold text-foreground tracking-tight" style="letter-spacing:-0.02em;">
              {`${t("schedule.heading")} ${year}`}
            </h1>
            <p class="mt-3 text-base md:text-lg text-muted-foreground max-w-2xl">
              {t("schedule.subtitle")}
            </p>
          </section>
          <section class="max-w-7xl mx-auto pb-20">
            <ScheduleGrid sessions={sessions} lang={lang} speakerInfo={speakerInfo} />
          </section>
        </>
      )}
    </main>
</Layout>
) : (
  <ComingSoonLayout flag="programme" lang={lang} />
)}
