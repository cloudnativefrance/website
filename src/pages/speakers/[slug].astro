---
import Layout from "../../layouts/Layout.astro";
import SpeakerProfile from "@/components/speakers/SpeakerProfile.astro";
import {
  getAllSpeakers,
  getSlug,
  getTalksForSpeaker,
  getCoSpeakersForTalk,
} from "@/lib/speakers";
import { useTranslations, getLocalePath } from "@/i18n/utils";

export async function getStaticPaths() {
  const speakers = await getAllSpeakers();
  return speakers.map((speaker) => ({
    params: { slug: getSlug(speaker.id) },
    props: { speaker },
  }));
}

const { speaker } = Astro.props;
const lang: "fr" = "fr";
const t = useTranslations(lang);
const slug = getSlug(speaker.id);
const talks = await getTalksForSpeaker("fr", slug);

const allSpeakers = await getAllSpeakers();
const speakerNameBySlug = new Map(allSpeakers.map((s) => [getSlug(s.id), s.data.name]));
const social = {
  twitter: speaker.data.twitter,
  linkedin: speaker.data.linkedin,
  github: speaker.data.github,
  bluesky: speaker.data.bluesky,
  website: speaker.data.website,
};
---

<Layout title={`${speaker.data.name} | ${t("site.title")}`}>
  <main class="px-4 md:px-6 lg:px-8 pt-8 md:pt-12 pb-16 md:pb-24">
    <SpeakerProfile
      name={speaker.data.name}
      company={speaker.data.company}
      role={speaker.data.role}
      photo={speaker.data.photo_url}
      social={social}
      lang={lang}
    >
      {speaker.data.bio && (
        <article class="prose prose-invert max-w-none">
          <p>{speaker.data.bio}</p>
        </article>
      )}

      <section slot="talks" class="mt-10">
        {talks.length > 0 ? (
          <>
            <h2 class="text-2xl font-bold text-foreground mb-4">
              {t("speakers.talks_heading")}
            </h2>
            <ul role="list" class="flex flex-col gap-3">
              {talks.map((talk) => {
                const coSlugs = getCoSpeakersForTalk(talk, slug);
                const coNames = coSlugs.map((cs) => ({
                  slug: cs,
                  name: speakerNameBySlug.get(cs) ?? cs,
                }));
                return (
                  <li class="rounded-lg border border-border bg-card p-4">
                    <h3 class="text-base font-bold text-foreground">{talk.title}</h3>
                    <p class="mt-1 text-sm text-muted-foreground">
                      {talk.format.charAt(0).toUpperCase() + talk.format.slice(1)} · {talk.durationMin} min
                      {talk.room && <span> · {talk.room}</span>}
                      {talk.track && <span> · {talk.track}</span>}
                    </p>
                    {coNames.length > 0 && (
                      <p class="mt-2 text-sm text-muted-foreground">
                        {t("speakers.cospeaker_prefix")}{" "}
                        {coNames.map((cs, i) => (
                          <>
                            <a href={getLocalePath(lang, `/speakers/${cs.slug}`)} class="text-primary hover:underline">
                              {cs.name}
                            </a>
                            {i < coNames.length - 1 && ", "}
                          </>
                        ))}
                      </p>
                    )}
                  </li>
                );
              })}
            </ul>
          </>
        ) : (
          <p class="text-sm text-muted-foreground mt-8">
            {t("speakers.no_talks")}
          </p>
        )}
      </section>
    </SpeakerProfile>
  </main>
</Layout>
