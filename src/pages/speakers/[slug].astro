---
import { getAllSpeakers, getSlug } from "@/lib/speakers";
import { EDITIONS, type Edition } from "@/lib/editions";

/**
 * Redirect shim for the former flat `/speakers/[slug]` URLs.
 * Enumerates every speaker slug across all editions, picks the latest
 * edition each slug appears in, and emits a 301 redirect HTML page to
 * `/speakers/<latest-year>/<slug>`.
 *
 * Slugs that match an edition year (e.g., "2026") are filtered out to
 * avoid a route collision with `/speakers/[year]/index.astro`.
 */
export async function getStaticPaths() {
  const editionYears = new Set(EDITIONS.map(String));
  const slugToLatestEdition = new Map<string, Edition>();
  for (const year of EDITIONS) {
    const speakers = await getAllSpeakers(year);
    for (const s of speakers) {
      const slug = getSlug(s.id);
      if (editionYears.has(slug)) continue;
      const existing = slugToLatestEdition.get(slug);
      if (!existing || year > existing) {
        slugToLatestEdition.set(slug, year);
      }
    }
  }
  return Array.from(slugToLatestEdition.entries()).map(([slug, year]) => ({
    params: { slug },
    props: { year },
  }));
}

const { year } = Astro.props as { year: Edition };
const { slug } = Astro.params;
return Astro.redirect(`/speakers/${year}/${slug}`, 301);
---
