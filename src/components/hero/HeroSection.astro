---
import GeoBackground from "@/components/patterns/GeoBackground.astro";
import CountdownTimer from "./CountdownTimer";
import { Badge } from "@/components/ui/badge";
import { getLangFromUrl, useTranslations, getLocalePath } from "@/i18n/utils";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import logo from "@/assets/logos/dark/logo.svg";
import ambiance00 from "@/assets/photos/ambiance/ambiance-00.jpg";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const TICKETING_URL = "https://tickets.cloudnativedays.fr/";
const SCHEDULE_URL: string | null = getLocalePath(lang, "/programme");
---

<section
  class="relative flex min-h-[80vh] lg:min-h-screen flex-col items-center justify-center overflow-hidden px-4 py-16 lg:py-24 text-center"
>
  <!-- Venue atmosphere photo as a very subtle backdrop -->
  <img
    src={ambiance00.src}
    alt=""
    aria-hidden="true"
    loading="eager"
    decoding="async"
    class="absolute inset-0 w-full h-full object-cover opacity-75 pointer-events-none"
  />
  <!-- Dark gradient wash keeps text readable over the photo -->
  <div
    class="absolute inset-0 bg-[linear-gradient(to_bottom,_var(--color-background)_0%,_color-mix(in_oklch,_var(--color-background)_80%,_transparent)_50%,_var(--color-background)_100%)] pointer-events-none"
  ></div>

  <GeoBackground class="absolute inset-0" />

  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--color-background)_0%,_var(--color-secondary)_100%)] opacity-40 pointer-events-none"
  />

  <div class="relative z-10 mx-auto flex w-full max-w-4xl flex-col items-center gap-8 md:gap-10">
    <h1 class="sr-only">{t("hero.title")}</h1>
    <img
      src={logo.src}
      alt={t("hero.logo_alt")}
      width={400}
      height={(400 * logo.height) / logo.width}
      class="w-full max-w-[260px] sm:max-w-[320px] md:max-w-[400px] h-auto"
      loading="eager"
      decoding="async"
    />

    <p
      class="flex w-full flex-wrap items-center justify-center gap-2 sm:gap-3 text-base sm:text-lg md:text-xl text-muted-foreground"
      style="line-height:1.4;"
    >
      <Badge className="bg-accent/15 text-accent text-sm sm:text-base font-normal uppercase tracking-widest rounded-full px-3 py-1">
        {t("hero.subtitle")}
      </Badge>
      <span>&mdash;</span>
      <span class="break-words">{t("hero.venue")}</span>
    </p>

    <p class="max-w-[720px] text-balance text-lg md:text-xl text-foreground" style="line-height:1.55;">
      {t("hero.description")}
    </p>

    <CountdownTimer client:load lang={lang} />

    <div class="flex flex-col gap-3 sm:flex-row sm:gap-4 md:gap-6">
      <a
        href={TICKETING_URL}
        target="_blank"
        rel="noopener noreferrer"
        class={cn(
          buttonVariants({ variant: "default", size: "lg" }),
          "h-[52px] px-8 text-lg font-bold shadow-[0_0_20px_oklch(62.5%_0.162_259.9_/_0.3)] hover:translate-y-[-1px] transition-all duration-150"
        )}
      >
        {t("hero.cta.register")}
      </a>
      {SCHEDULE_URL && (
        <a
          href={SCHEDULE_URL}
          class={cn(
            buttonVariants({ variant: "outline", size: "lg" }),
            "h-[52px] px-8 text-lg font-bold"
          )}
        >
          {t("hero.cta.schedule")}
        </a>
      )}
      <a
        href="https://d820b57b.sibforms.com/serve/MUIFAMhQae0KzNYxFvx6QSRhBI9sMf8V95ghzeac7poMILWncQNi6r_1yx56s6zfRIyfhiGqhx24CmxsMTthOrreePBCipj7yL0_QdwgtcZxfkzzebIQKjwCga2lb7IOvyDV9qZBzHh-wJVW5k8zHIKorqxmkJDZ3-wxP_jPo7z-0nQBCgoiXjTLPwEAMI52iPoy5OLEibdt3bnF"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={t("hero.cta.newsletter_aria")}
        class={cn(
          buttonVariants({ variant: "ghost", size: "lg" }),
          "h-[52px] px-8 text-lg font-bold",
          "text-accent",
          "hover:bg-accent/10 hover:text-accent",
          "focus-visible:ring-accent/50",
          "gap-2"
        )}
      >
        <svg
          aria-hidden="true"
          focusable="false"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="shrink-0"
        >
          <rect width="20" height="16" x="2" y="4" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
        {t("hero.cta.newsletter")}
      </a>
    </div>
  </div>
</section>
