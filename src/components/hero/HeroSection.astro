---
import GeoBackground from "@/components/patterns/GeoBackground.astro";
import CountdownTimer from "./CountdownTimer";
import { Badge } from "@/components/ui/badge";
import { getLangFromUrl, useTranslations, getLocalePath } from "@/i18n/utils";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import logo from "@/assets/logos/dark/logo.svg";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const TICKETING_URL = "https://tickets.cloudnativedays.fr/";
// Schedule route unavailable until Phase 7 ships /programme — hide the CTA until then.
const SCHEDULE_URL: string | null = null;
---

<section
  class="relative flex min-h-[80vh] lg:min-h-screen flex-col items-center justify-center overflow-hidden px-4 py-16 lg:py-24 text-center"
>
  <GeoBackground class="absolute inset-0" />

  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--color-background)_0%,_var(--color-secondary)_100%)] opacity-60"
  />

  <div class="relative z-10 mx-auto flex max-w-4xl flex-col items-center gap-8 md:gap-10">
    <img
      src={logo.src}
      alt={t("hero.logo_alt")}
      width={400}
      height={(400 * logo.height) / logo.width}
      class="w-[320px] md:w-[400px] h-auto"
      loading="eager"
      decoding="async"
    />

    <p
      class="flex flex-wrap items-center justify-center gap-3 text-lg md:text-xl text-muted-foreground"
      style="line-height:1.4;"
    >
      <Badge className="bg-accent/15 text-accent text-base font-normal uppercase tracking-widest rounded-full px-3 py-1">
        {t("hero.subtitle")}
      </Badge>
      <span>&mdash;</span>
      <span>{t("hero.venue")}</span>
    </p>

    <p class="max-w-[720px] text-balance text-lg md:text-xl text-foreground" style="line-height:1.55;">
      {t("hero.description")}
    </p>

    <CountdownTimer client:load lang={lang} />

    <div class="flex flex-col gap-3 sm:flex-row sm:gap-4">
      <a
        href={TICKETING_URL}
        target="_blank"
        rel="noopener noreferrer"
        class={cn(
          buttonVariants({ variant: "default", size: "lg" }),
          "h-[52px] px-8 text-lg font-bold shadow-[0_0_20px_oklch(62.5%_0.162_259.9_/_0.3)] hover:translate-y-[-1px] transition-all duration-150"
        )}
      >
        {t("hero.cta.register")}
      </a>
      {SCHEDULE_URL && (
        <a
          href={SCHEDULE_URL}
          class={cn(
            buttonVariants({ variant: "outline", size: "lg" }),
            "h-[52px] px-8 text-lg font-bold"
          )}
        >
          {t("hero.cta.schedule")}
        </a>
      )}
    </div>
  </div>
</section>
