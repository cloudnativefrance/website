---
/**
 * Phase 19 (D-08, D-09, D-10, A11Y-04): 10-photo responsive grid for the
 * dedicated `/2023` + `/en/2023` page.
 *
 * - astro:assets `<Picture>` → AVIF/WebP/JPG fallback chain
 * - aspect-[4/3] on every tile → dimensions reserved, CLS <=0.02
 * - Each tile is a <button type="button"> that opens the lightbox.
 *   A data-lightbox-trigger attribute carries the photo index; the lightbox
 *   controller (Edition2023Lightbox.astro) listens for clicks on these.
 * - Unique descriptive alt text per photo (FR or EN, injected by caller).
 */
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Photo {
  src: ImageMetadata;
  alt: string;
}

interface Props {
  photos: ReadonlyArray<Photo>;
  openLabelTemplate: string; // e.g. "Ouvrir la photo : {alt}" — {alt} substituted per tile
}

const { photos, openLabelTemplate } = Astro.props;
---
<div
  class="mt-12 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4"
  data-edition-2023-photo-grid
>
  {photos.map((p, i) => (
    <button
      type="button"
      data-lightbox-trigger={i}
      aria-label={openLabelTemplate.replace("{alt}", p.alt)}
      class="relative block w-full overflow-hidden rounded-md bg-card border border-border aspect-[4/3] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 transition-opacity hover:opacity-90"
    >
      <Picture
        src={p.src}
        alt={p.alt}
        widths={[400, 600, 900, 1200]}
        sizes="(min-width: 1024px) 25vw, (min-width: 768px) 33vw, (min-width: 640px) 50vw, 100vw"
        formats={["avif", "webp"]}
        loading="lazy"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover"
      />
    </button>
  ))}
</div>
