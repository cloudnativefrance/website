---
/**
 * Edition2026Combined.astro
 *
 * Homepage section that wraps the 2026 recap into one block:
 *   1. Section heading (h2)
 *   2. YouTube aftermovie embed (youtube-nocookie per D-12)
 *   3. 3-photo asymmetric mosaic (1 hero + 2 medium)
 *   4. Most-watched talks strip — 4 YouTube thumbnails + "View all replays" link
 *
 * Pure Astro SSR. Zero hydration directives. DS tokens only.
 * Resolves its own i18n + data so consumers can mount it with no props,
 * but exports a Props interface for future flexibility.
 */
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import { EDITION_2026 } from "@/lib/editions-data";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import YouTubeFacade from "./YouTubeFacade.astro";
import TopReplaysStrip from "./TopReplaysStrip.astro";

export interface Props {
  /** Anchor id for deep-linking. Recommended: "edition-2026". */
  id?: string;
  /** Localised h2 copy, e.g. t("editions.2026.heading"). */
  heading?: string;
  /** 3 photos in render order. Size assignments per UI-SPEC §3. */
  photos?: ReadonlyArray<{ src: ImageMetadata; alt: string; size: "hero" | "medium" }>;
  /** YouTube embed config — uses youtube-nocookie. */
  video?: { youtubeId: string; caption: string };
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const props = Astro.props as Props;

// Default anchor id="edition-2026" enables deep-linking and matches Phase 26 expectations.
const id = props.id ?? "edition-2026";
const heading = props.heading ?? t("editions.2026.heading");
const photos =
  props.photos ??
  EDITION_2026.thumbnails.map((p) => ({
    src: p.src,
    alt: t(p.altKey),
    size: p.size as "hero" | "medium",
  }));
const video = props.video ?? {
  youtubeId: EDITION_2026.youtubeId,
  caption: t("editions.2026.video_caption"),
};
/**
 * Tailwind grid classes — UI-SPEC §3 ("1 large left + 2 stacked-equivalent right on desktop").
 * Hero: full width on mobile, left 2/3 on desktop spanning both rows.
 * Medium: half width on mobile (side-by-side under hero), right 1/3 on desktop, one per row.
 */
const cellClass = {
  hero: "col-span-12 md:col-span-8 md:row-span-2",
  medium: "col-span-6 md:col-span-4 md:row-span-1",
} as const;
---
<section
  id={id}
  class="relative max-w-6xl mx-auto px-4 md:px-6 lg:px-8 pt-8 md:pt-12 pb-6 md:pb-10"
>
  <h2
    class="text-3xl md:text-4xl font-bold text-foreground tracking-tight"
    style="letter-spacing:-0.02em;"
  >
    {heading}
  </h2>

  {/* YouTube video embed via click-to-play facade (saves ~700 KiB on initial load) */}
  {video && (
    <figure class="mt-12 max-w-4xl mx-auto">
      <YouTubeFacade
        videoId={video.youtubeId}
        title={video.caption}
        playAriaLabel={t("editions.2026.video_play_aria").replace("{title}", video.caption)}
      />
      <figcaption class="mt-3 text-sm text-muted-foreground">{video.caption}</figcaption>
    </figure>
  )}

  {/* Photo mosaic — 3 thumbnails, 1 hero + 2 medium */}
  {photos && photos.length > 0 && (
    <div class="mt-12 grid grid-cols-12 gap-3 md:gap-4 [grid-auto-rows:12rem] md:[grid-auto-rows:14rem]">
      {photos.map((p) => (
        <figure
          class={`${cellClass[p.size]} overflow-hidden rounded-md bg-card border border-border`}
        >
          <Picture
            src={p.src}
            alt={p.alt}
            widths={[400, 800, 1200]}
            sizes={p.size === "hero" ? "(min-width: 768px) 66vw, 100vw" : "(min-width: 768px) 33vw, 50vw"}
            formats={["avif", "webp"]}
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover"
          />
        </figure>
      ))}
    </div>
  )}

  {/* Most-watched talks — 4-thumbnail strip (replaces former replays + gallery CTAs). */}
  <TopReplaysStrip
    replays={EDITION_2026.topReplays}
    playlistUrl={EDITION_2026.replaysUrl}
    eyebrowKey="editions.2026.top_replays_eyebrow"
    viewAllKey="editions.2026.view_all_replays"
    class="mt-12"
  />

</section>
