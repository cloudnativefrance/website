---
/**
 * EDIT-07 (17-04): Minimal past-edition section for historical editions (2023+).
 *
 * Compact vertical stack: row 1 = logo + title, row 2 = 3 photos (full-width), row 3 = playlist link.
 * No rail, no h2, no stats, no video embed, no brand-callout paragraph.
 *
 * Consumed by src/pages/index.astro + src/pages/en/index.astro (2023 mount).
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  id?: string;
  title: string;
  photos: Array<{ src: ImageMetadata; alt: string }>;
  logo: ImageMetadata;
  logoAlt: string;
  playlistLink: { label: string; href: string };
}

const { id, title, photos, logo, logoAlt, playlistLink } = Astro.props;
const visiblePhotos = photos.slice(0, 3);
---
<section
  id={id}
  class="relative max-w-6xl mx-auto px-4 md:px-6 lg:px-8 py-16 md:py-24"
>
  <div class="flex flex-col gap-8 md:gap-10">
    {/* ROW 1: logo + title */}
    <div class="flex items-center gap-4">
      <div class="w-20 md:w-24 shrink-0">
        <Image src={logo} alt={logoAlt} class="w-full h-auto" />
      </div>
      <h2 class="text-2xl md:text-3xl font-semibold text-foreground leading-tight">
        {title}
      </h2>
    </div>

    {/* ROW 2: photos (full-width 3-col grid) */}
    <div class="grid grid-cols-3 gap-3 md:gap-4">
      {visiblePhotos.map((p) => (
        <figure class="overflow-hidden rounded-md bg-card border border-border aspect-[4/3]">
          <Image
            src={p.src}
            alt={p.alt}
            widths={[400, 800, 1200]}
            sizes="(min-width: 1024px) 33vw, (min-width: 768px) 33vw, 33vw"
            class="w-full h-full object-cover"
          />
        </figure>
      ))}
    </div>

    {/* ROW 3: playlist link */}
    <div class="flex">
      <a
        href={playlistLink.href}
        class="inline-flex items-center gap-2 text-base font-semibold text-primary hover:underline"
        rel="noopener"
        target="_blank"
      >
        {playlistLink.label} <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
