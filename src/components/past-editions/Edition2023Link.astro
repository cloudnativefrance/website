---
/**
 * Homepage minimal 2023 bloc (Phase 24 — ED23-01).
 *
 * Renders ONLY the KCD 2023 brand logo + h2 title + single text link to /2023.
 * No photos, no playlist link, no brand-history prose — the dedicated /2023 page
 * is the canonical deep-dive destination (this component is a pointer to it).
 *
 * Replaces PastEditionMinimal.astro on the homepage starting in Phase 26.
 * Phase 24 only BUILDS this component; Phase 26 (Homepage Wiring) mounts it,
 * removes the PastEditionMinimal import, and deletes the now-orphan file.
 *
 * Fully prop-driven so the Stitch mockup → code mapping is 1:1 with no
 * flag-driven branches. The caller (Phase 26) resolves i18n + locale-aware
 * href before passing props — see UI-SPEC §Props Interface for the caller snippet.
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

export interface Props {
  /** Anchor id for deep-linking. Recommended: "edition-2023". */
  id?: string;
  /** Localised h2 copy, e.g. t("editions.2023.compact_title"). */
  heading: string;
  /** KCD 2023 brand logo (imported from editions-data.ts as ImageMetadata). */
  logo: ImageMetadata;
  /** Localised alt text for the KCD logo. */
  logoAlt: string;
  /** Localised CTA label INCLUDING its trailing arrow (Pattern A — the i18n value already carries ' →'). */
  viewPageLabel: string;
  /** CTA destination — locale-aware ("/2023" vs "/en/2023"). */
  viewPageHref: string;
}

const { id = "edition-2023", heading, logo, logoAlt, viewPageLabel, viewPageHref } = Astro.props;
---
<section
  id={id}
  class="relative max-w-6xl mx-auto px-4 md:px-6 lg:px-8 py-16 md:py-24"
>
  {/* 1. Header row — logo + h2. Stacks on mobile, flex-row from sm: upward. */}
  <div class="flex flex-col sm:flex-row sm:items-center sm:gap-6 gap-4">
    <div class="w-20 md:w-24 shrink-0">
      <Image src={logo} alt={logoAlt} class="w-full h-auto" />
    </div>
    <h2 class="text-2xl md:text-3xl font-semibold text-foreground tracking-tight leading-tight">
      {heading}
    </h2>
  </div>

  {/* 2. CTA row — single text link to /2023. Arrow is ALREADY in viewPageLabel (Pattern A) — do NOT add a decorative <span>. */}
  <p class="mt-6">
    <a
      href={viewPageHref}
      class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring rounded-sm"
    >
      {viewPageLabel}
    </a>
  </p>
</section>
