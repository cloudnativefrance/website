---
import type { Locale } from "@/i18n/ui";
import { useTranslations, getLocalePath } from "@/i18n/utils";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const contactHref = getLocalePath(lang, "/contact");
---

<section class="py-16">
  <div class="max-w-[640px] mx-auto text-center px-4">
    <h2 class="text-2xl font-semibold text-foreground">{t("sponsors.cta.heading")}</h2>
    <p class="text-base text-muted-foreground mt-4">{t("sponsors.cta.body")}</p>
    <a
      href={contactHref}
      class="inline-flex items-center justify-center h-12 rounded-md bg-primary text-primary-foreground text-base font-semibold px-6 mt-8 transition-opacity motion-safe:hover:-translate-y-0.5 hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
    >
      {t("sponsors.cta.button")}
    </a>
  </div>
</section>
