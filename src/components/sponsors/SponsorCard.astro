---
import type { Locale } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";
import { safeUrl, safeLogoPath, type SponsorEntry } from "@/lib/sponsor-utils";

interface Props {
  sponsor: SponsorEntry;
  lang: Locale;
  tier:
    | "platinum"
    | "gold"
    | "silver"
    | "end_user"
    | "community"
    | "experiences"
    | "media"
    | "institutional";
}

const { sponsor, lang, tier } = Astro.props;
const t = useTranslations(lang);

const description = lang === "fr" ? sponsor.data.description_fr : sponsor.data.description_en;
const safeHref = safeUrl(sponsor.data.url);
const logoSrc = safeLogoPath(sponsor.data.logo);
const ariaLabel = t("sponsors.card.aria").replace("{name}", sponsor.data.name);

// Tier-specific padding
const tierPadding: Record<Props["tier"], string> = {
  platinum: "p-8",
  gold: "p-6",
  silver: "p-4",
  end_user: "p-4",
  community: "p-3",
  experiences: "p-4",
  media: "p-4",
  institutional: "p-3",
};

// Tier-specific logo dimensions. `experiences` and `media` mirror `end_user`
// per Apr-2026 stakeholder feedback to keep partner-card sizes balanced.
const tierLogoSize: Record<Props["tier"], string> = {
  platinum: "max-w-[300px] max-h-28",
  gold: "max-w-[160px] max-h-16",
  silver: "max-w-[120px] max-h-14",
  end_user: "max-w-[140px] max-h-14",
  community: "max-w-[88px] max-h-10",
  experiences: "max-w-[140px] max-h-14",
  media: "max-w-[140px] max-h-14",
  institutional: "max-w-[88px] max-h-10",
};

// Per-tier minimum height — keeps every card in a tier visually balanced even
// when logos have wildly different aspect ratios. Combined with `auto-rows-fr`
// on the grid, all cards in the same tier render at identical height.
const tierMinH: Record<Props["tier"], string> = {
  platinum: "min-h-[160px]",
  gold: "min-h-[112px]",
  silver: "min-h-[96px]",
  end_user: "min-h-[112px]",
  community: "min-h-[80px]",
  experiences: "min-h-[112px]",
  media: "min-h-[112px]",
  institutional: "min-h-[80px]",
};

const baseCardClass = `bg-card border border-border rounded-lg ${tierPadding[tier]} ${tierMinH[tier]} h-full flex items-center justify-center`;
const linkExtrasClass =
  "transition-all duration-200 motion-safe:hover:-translate-y-0.5 hover:border-primary/50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background";
const imgClass = `${tierLogoSize[tier]} object-contain`;
---

{safeHref ? (
  <a
    href={safeHref}
    target="_blank"
    rel="noopener noreferrer"
    title={description}
    aria-label={ariaLabel}
    class={`${baseCardClass} ${linkExtrasClass}`}
  >
    {logoSrc ? (
      <img
        src={logoSrc}
        alt={sponsor.data.name}
        class={imgClass}
        loading="lazy"
        decoding="async"
      />
    ) : null}
  </a>
) : (
  <div class={baseCardClass} title={description}>
    {logoSrc ? (
      <img
        src={logoSrc}
        alt={sponsor.data.name}
        class={imgClass}
        loading="lazy"
        decoding="async"
      />
    ) : null}
  </div>
)}
