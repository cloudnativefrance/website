---
import type { Locale } from "@/i18n/ui";
import SponsorCard from "@/components/sponsors/SponsorCard.astro";
import type { SponsorEntry } from "@/lib/sponsor-utils";

interface Props {
  tier: "platinum" | "gold" | "silver" | "community";
  sponsors: SponsorEntry[];
  lang: Locale;
  title: string;
}

const { tier, sponsors, lang, title } = Astro.props;

// Grid classes per tier (UI-SPEC canonical expressions)
const tierGrid: Record<Props["tier"], string> = {
  platinum: "grid grid-cols-1 max-w-[512px] mx-auto",
  gold: "grid grid-cols-1 sm:grid-cols-2 gap-6 sm:gap-8",
  silver: "grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6",
  community: "grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-3 lg:gap-4",
};
---

<section class="py-16">
  <h2 class="text-2xl font-semibold tracking-wider uppercase text-foreground text-center mb-8">
    {title}
  </h2>
  <div class={tierGrid[tier]}>
    {sponsors.map((s) => (
      <SponsorCard sponsor={s} lang={lang} tier={tier} />
    ))}
  </div>
</section>
