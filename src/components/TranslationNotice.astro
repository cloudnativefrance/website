---
import { defaultLang, type Locale } from "@/i18n/ui";
import { getLangFromUrl, useTranslations, getLocalePath } from "@/i18n/utils";

interface Props {
  originalLocale?: Locale;
}

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const { originalLocale = currentLang === "fr" ? "en" : "fr" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<div class="w-full border-y border-border bg-card px-4 py-4">
  <div class="flex items-start gap-3">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="mt-0.5 shrink-0 text-primary"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <path d="M12 16v-4"></path>
      <path d="M12 8h.01"></path>
    </svg>
    <div class="flex flex-col gap-1">
      <p class="text-sm font-semibold text-foreground">{t("fallback.heading")}</p>
      <p class="text-sm text-muted-foreground">{t("fallback.body")}</p>
      <a
        href={getLocalePath(originalLocale, currentPath)}
        class="text-sm font-semibold text-primary underline-offset-2 hover:underline"
      >
        {t("fallback.cta")}
      </a>
    </div>
  </div>
</div>
