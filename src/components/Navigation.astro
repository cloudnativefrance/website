---
import { getLangFromUrl, useTranslations, getLocalePath } from "@/i18n/utils";
import { TARGET_DATE } from "@/lib/event";
import { EDITIONS } from "@/lib/editions";
import LanguageToggle from "@/components/LanguageToggle.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import NavDropdown from "@/components/NavDropdown.astro";
import logoCompactDark from "@/assets/logos/dark/logo-notext.svg";
import logoCompactLight from "@/assets/logos/principal/logo-notext.svg";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const navItems: Array<{
  key: "nav.replays" | "nav.tickets" | "nav.cfp";
  path: string;
  dead: boolean;
  postEventOnly?: boolean;
}> = [
  { key: "nav.tickets",  path: "/tickets",   dead: false },
  { key: "nav.cfp",      path: "/cfp",       dead: false },
  { key: "nav.replays",  path: "/replays",   dead: false, postEventOnly: true },
];

function isActive(currentPath: string, href: string, dead: boolean): boolean {
  if (dead) return false;
  if (href === "/" || href === "/en" || href === "/en/") {
    return currentPath === href || currentPath === href + "/";
  }
  return currentPath.startsWith(href);
}

const links = navItems.map(({ key, path, dead, postEventOnly }) => ({
  key,
  label: t(key),
  href: getLocalePath(lang, path),
  active: isActive(currentPath, getLocalePath(lang, path), dead),
  postEventOnly: !!postEventOnly,
}));

const editionsDesc = [...EDITIONS].sort((a, b) => b - a);

function sectionDropdown(
  section: "programme" | "sponsors",
  labelKey: "nav.programme.label" | "nav.sponsors.label",
) {
  const basePath = `/${section}`;
  const localizedBase = getLocalePath(lang, basePath);
  return {
    key: labelKey,
    label: t(labelKey),
    active: currentPath.startsWith(localizedBase),
    items: editionsDesc.map((year) => ({
      href: getLocalePath(lang, `${basePath}/${year}`),
      label: `${t(labelKey)} ${year}`,
      current: currentPath === getLocalePath(lang, `${basePath}/${year}`),
    })),
  };
}

const programmeDD = sectionDropdown("programme", "nav.programme.label");
const sponsorsDD  = sectionDropdown("sponsors",  "nav.sponsors.label");

const aboutDD = (() => {
  const aboutPath = getLocalePath(lang, "/decouvrir");
  const venuePath = getLocalePath(lang, "/informations-utiles");
  const teamPath = getLocalePath(lang, "/team");
  return {
    key: "nav.home",
    label: t("nav.home"),
    active:
      currentPath.startsWith(aboutPath) ||
      currentPath.startsWith(venuePath) ||
      currentPath.startsWith(teamPath),
    items: [
      { href: aboutPath, label: t("about.subnav.discover"), current: currentPath.startsWith(aboutPath) },
      { href: venuePath, label: t("about.subnav.venue"),    current: currentPath.startsWith(venuePath) },
      { href: teamPath,  label: t("about.subnav.team"),     current: currentPath.startsWith(teamPath) },
    ],
  };
})();

const homeHref = getLocalePath(lang, "/");
const ctaLabel = t("hero.cta.register");
const TICKETING_URL = "https://tickets.cloudnativedays.fr/";

// Lookup so the JSX can render links in an explicit order, interleaved with
// dropdowns. Mobile menu reuses the same map below.
const linkByKey = Object.fromEntries(links.map((l) => [l.key, l])) as Record<
  (typeof links)[number]["key"],
  (typeof links)[number]
>;
const ticketsLink = linkByKey["nav.tickets"];
const cfpLink = linkByKey["nav.cfp"];
const replaysLink = linkByKey["nav.replays"];
---

<header
  id="site-header"
  data-target-date={TARGET_DATE}
  class="sticky top-0 z-50 backdrop-blur-sm bg-background/90 border-b border-transparent transition-[border-color,box-shadow] duration-200"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 md:px-6">
    <!-- Logo (theme-aware: only the variant matching the current .dark class renders) -->
    <a href={homeHref} class="shrink-0 flex items-center" aria-label="CND France">
      <img src={logoCompactLight.src} alt="CND France" class="dark:hidden h-8 md:h-10" />
      <img src={logoCompactDark.src} alt="CND France" class="hidden dark:block h-8 md:h-10" loading="lazy" />
    </a>

    <!-- Desktop links — explicit order: À propos, Partenaires, Billetterie, Programme, CFP, Replays. -->
    <ul class="hidden md:flex items-center gap-10" role="list">
      <NavDropdown {...aboutDD} />
      <NavDropdown {...sponsorsDD} />
      {[ticketsLink, cfpLink, replaysLink].map(({ key, label, href, active, postEventOnly }, i) => (
        <Fragment>
          {/* Insert the Programme dropdown between Billetterie and CFP. */}
          {i === 1 && <NavDropdown {...programmeDD} />}
          <li
            data-post-event={postEventOnly ? "true" : undefined}
            class:list={[postEventOnly && "hidden"]}
          >
            <a
              href={href}
              data-nav-key={key}
              aria-current={active ? "page" : undefined}
              class:list={[
                "text-lg font-medium text-foreground transition-colors pb-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded-sm",
                active
                  ? "border-b-2 border-primary"
                  : "border-b-2 border-transparent hover:border-primary/60",
              ]}
            >
              {label}
            </a>
          </li>
        </Fragment>
      ))}
    </ul>

    <!-- Right side -->
    <div class="flex items-center gap-3">
      <a
        href={TICKETING_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground text-sm font-medium px-4 h-9 transition-opacity hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
      >
        {ctaLabel}
      </a>
      <ThemeToggle />
      <LanguageToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        class="md:hidden inline-flex items-center justify-center w-11 h-11 rounded-md text-foreground hover:bg-muted focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-open"  xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6"  x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-background/95 backdrop-blur-sm">
    <ul class="px-4 py-2" role="list">
      <li class="flex items-center justify-end gap-3 py-3 border-b border-border">
        <ThemeToggle />
        <LanguageToggle />
      </li>
      {(() => {
        // Same order as desktop. JSX-in-callback so we can interleave dropdowns
        // with plain links in a single ordered render.
        const order: Array<
          | { kind: "dd"; dd: typeof aboutDD }
          | { kind: "link"; link: typeof ticketsLink }
        > = [
          { kind: "dd",   dd: aboutDD },
          { kind: "dd",   dd: sponsorsDD },
          { kind: "link", link: ticketsLink },
          { kind: "dd",   dd: programmeDD },
          { kind: "link", link: cfpLink },
          { kind: "link", link: replaysLink },
        ];
        return order.map((entry) =>
          entry.kind === "link" ? (
            <li
              data-post-event={entry.link.postEventOnly ? "true" : undefined}
              class:list={[entry.link.postEventOnly && "hidden"]}
            >
              <a
                href={entry.link.href}
                aria-current={entry.link.active ? "page" : undefined}
                class:list={[
                  "flex items-center min-h-11 px-2 py-3 text-sm font-medium rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring",
                  entry.link.active ? "text-primary" : "text-foreground hover:bg-muted",
                ]}
              >
                {entry.link.label}
              </a>
            </li>
          ) : (
            <li>
              <p class="px-2 py-3 text-xs font-semibold uppercase tracking-[0.2em] text-muted-foreground">{entry.dd.label}</p>
              <ul class="pl-2">
                {entry.dd.items.map((it) => (
                  <li>
                    <a
                      href={it.href}
                      aria-current={it.current ? "page" : undefined}
                      class:list={[
                        "flex items-center min-h-11 px-2 py-3 text-sm font-medium rounded-md",
                        it.current ? "text-primary" : "text-foreground hover:bg-muted",
                      ]}
                    >
                      {it.label}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          ),
        );
      })()}
      <li>
        <a href="#" class="flex items-center justify-center min-h-11 mx-2 my-3 px-4 rounded-md bg-primary text-primary-foreground text-sm font-medium">
          {ctaLabel}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Mobile menu toggle with body scroll lock
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  btn?.addEventListener("click", () => {
    const isHidden = menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", isHidden ? "true" : "false");
    document.body.classList.toggle("overflow-hidden", !!isHidden);
  });

  // Scroll divider + subtle shadow — visible border + drop shadow when page is scrolled.
  const header = document.getElementById("site-header");
  if (header) {
    const onScroll = () => {
      const scrolled = window.scrollY > 0;
      header.classList.toggle("border-border", scrolled);
      header.classList.toggle("shadow-[0_4px_12px_rgba(0,0,0,0.2)]", scrolled);
      header.classList.toggle("border-transparent", !scrolled);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  // Reveal post-event-only nav entries (e.g. /replays) once TARGET_DATE has passed.
  // TARGET_DATE is the single source of truth in src/lib/event.ts — read via the
  // header's data-target-date attribute to avoid inlining a drift-prone literal.
  const targetDate = Number(
    document.getElementById("site-header")?.dataset.targetDate,
  );
  if (Number.isFinite(targetDate) && Date.now() > targetDate) {
    document
      .querySelectorAll<HTMLElement>("[data-post-event='true']")
      .forEach((el) => {
        el.classList.remove("hidden");
      });
  }
</script>
