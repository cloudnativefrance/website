---
import { getLangFromUrl, useTranslations, getLocalePath } from "@/i18n/utils";
import { NEWSLETTER_URL } from "@/lib/event";
import logoFullDark from "@/assets/logos/dark/logo.svg";
import logoFullLight from "@/assets/logos/principal/logo.svg";
import SocialLinks from "@/components/SocialLinks.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

// SAME nav items as Navigation.astro (order mirrored for muscle memory).
const navItems = [
  { key: "nav.home"     as const, path: "/" },
  { key: "nav.speakers" as const, path: "/speakers" },
  { key: "nav.schedule" as const, path: "/programme" },
  { key: "nav.sponsors" as const, path: "/sponsors" },
  { key: "nav.venue"    as const, path: "/informations-utiles" },
  { key: "nav.team"     as const, path: "/team" },
  { key: "nav.contact"  as const, path: "/contact" },
];

function isActive(currentPath: string, href: string): boolean {
  if (href === "/" || href === "/en" || href === "/en/") {
    return currentPath === href || currentPath === href + "/";
  }
  return currentPath.startsWith(href);
}

const navLinks = navItems.map(({ key, path }) => {
  const href = getLocalePath(lang, path);
  return { key, label: t(key), href, active: isActive(currentPath, href) };
});

const legalLinks = [
  { key: "footer.legal.coc"     as const, path: "/code-of-conduct" },
  { key: "footer.legal.privacy" as const, path: "/privacy" },
  { key: "footer.legal.terms"   as const, path: "/terms" },
].map(({ key, path }) => ({ key, label: t(key), href: getLocalePath(lang, path) }));

---

<footer
  role="contentinfo"
  aria-label={t("footer.landmark_aria")}
  class="bg-background text-muted-foreground mt-12"
>
  <div class="mx-auto max-w-7xl px-4 md:px-6 py-12">
      <!-- Newsletter CTA -->
      <div class="flex flex-col items-center gap-4 mb-12 pb-12 border-b border-border">
        <h2 class="text-2xl sm:text-3xl font-bold text-foreground text-center">
          {t("footer.newsletter.heading")}
        </h2>
        <a
          href={NEWSLETTER_URL}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t("hero.cta.newsletter_aria")}
          class="inline-flex items-center justify-center gap-2 h-[52px] px-8 text-lg font-bold rounded-md border-2 border-destructive text-destructive bg-transparent hover:bg-destructive/10 hover:text-destructive hover:border-destructive hover:shadow-[0_0_0_4px_oklch(54.0%_0.216_25.2_/_0.15)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-destructive/50 focus-visible:ring-offset-2 focus-visible:ring-offset-background transition-all duration-150"
        >
          <svg
            aria-hidden="true"
            focusable="false"
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="shrink-0"
          >
            <rect width="20" height="16" x="2" y="4" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
          {t("hero.cta.newsletter")}
        </a>
      </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 lg:gap-12">

      <!-- Column 1: Brand -->
      <div>
        <img src={logoFullLight.src} alt="Cloud Native Days France" class="dark:hidden h-8" loading="lazy" />
        <img src={logoFullDark.src} alt="Cloud Native Days France" class="hidden dark:block h-8" />
        <p class="text-sm text-muted-foreground mt-4">{t("footer.tagline")}</p>
        <p class="text-sm text-muted-foreground mt-3">{t("footer.association")}</p>
      </div>

      <!-- Column 2: Quick nav -->
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-foreground">{t("footer.nav.heading")}</h2>
        <ul class="mt-4 space-y-3" role="list">
          {navLinks.map(({ label, href, active }) => (
            <li>
              <a
                href={href}
                aria-current={active ? "page" : undefined}
                class:list={[
                  "text-sm transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded-sm",
                  active ? "text-primary" : "text-muted-foreground hover:text-primary",
                ]}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Community + Legal -->
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-foreground">{t("footer.community.heading")}</h2>
        <SocialLinks class="mt-4" />

        <h2 class="text-sm font-semibold uppercase tracking-wider text-foreground mt-8">{t("footer.legal.heading")}</h2>
        <ul class="mt-4 space-y-3" role="list">
          {legalLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class="text-sm text-muted-foreground hover:text-primary transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded-sm"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="mt-8 pt-6 border-t border-border">
      <p class="text-xs text-muted-foreground">{t("footer.copyright")}</p>
    </div>
  </div>
</footer>
