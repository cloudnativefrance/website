---
import TeamMemberCard from "@/components/team/TeamMemberCard.astro";
import type { CollectionEntry } from "astro:content";
import type { Locale } from "@/i18n/ui";

interface Props {
  group: "core" | "program-committee" | "volunteers";
  members: CollectionEntry<"team">[];
  lang: Locale;
  title: string;
  subtitle?: string;
}

const { members, lang, title, subtitle } = Astro.props;
---

<section class="py-12">
  <h2 class="text-2xl font-semibold text-foreground">{title}</h2>
  {subtitle && (
    <p class="mt-2 text-base text-muted-foreground max-w-3xl">{subtitle}</p>
  )}
  <div
    class="mt-4 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-8"
  >
    {members.map((m) => <TeamMemberCard member={m} lang={lang} />)}
  </div>
</section>
