---
import type { SessionRow } from "@/lib/schedule";
import { endTime, formatTime, listFormats, listLevels, listRooms, listTracks } from "@/lib/schedule";
import type { Locale } from "@/i18n/ui";
import { useTranslations, getLocalePath } from "@/i18n/utils";

interface Props {
  sessions: SessionRow[];
  lang: Locale;
  /** Map of slug → display name for resolving speaker references in session cards. */
  speakerNames: Map<string, string>;
}

const { sessions, lang, speakerNames } = Astro.props;
const t = useTranslations(lang);

const rooms = listRooms(sessions);
const formats = listFormats(sessions);
const tracks = listTracks(sessions);
const levels = listLevels(sessions);

// Compute schedule window
const times = sessions
  .map((s) => s.startTime)
  .filter(Boolean)
  .sort();
const firstStart = times[0];
const dayDateIso = firstStart ? firstStart.slice(0, 10) : "";

function toMinutes(iso: string): number {
  const m = iso.match(/T(\d{2}):(\d{2})/);
  return m ? Number(m[1]) * 60 + Number(m[2]) : 0;
}

// Grid window: 30 min before earliest, 30 min after latest session end
const allMinutes = sessions.flatMap((s) => {
  const start = toMinutes(s.startTime);
  return [start, start + s.durationMin];
});
const GRID_START = Math.floor((Math.min(...allMinutes, 540) - 0) / 60) * 60; // floor to hour
const GRID_END = Math.ceil((Math.max(...allMinutes, 1140) + 0) / 60) * 60;
const GRID_ROWS = (GRID_END - GRID_START) / 5; // 5 min per row

// Time labels every 30 minutes
const timeLabels: { label: string; row: number }[] = [];
for (let m = GRID_START; m <= GRID_END; m += 30) {
  const h = String(Math.floor(m / 60)).padStart(2, "0");
  const mn = String(m % 60).padStart(2, "0");
  timeLabels.push({ label: `${h}:${mn}`, row: (m - GRID_START) / 5 + 1 });
}

function sessionSpeakerLinks(s: SessionRow) {
  // Resolve speaker refs to display names. When the slug is known, link to the
  // profile page; otherwise the ref is already a full name so use it verbatim.
  return s.speakers.map((ref) => {
    const resolvedName = speakerNames.get(ref);
    if (resolvedName) {
      return { label: resolvedName, href: getLocalePath(lang, `/speakers/${ref}`) };
    }
    return { label: ref, href: null };
  });
}

function formatChipClass(fmt: string) {
  switch (fmt) {
    case "keynote":
      return "bg-accent/15 text-accent border-accent/30";
    case "lightning":
      return "bg-[color:var(--color-tertiary)]/15 border-[color:var(--color-tertiary)]/30";
    case "workshop":
      return "bg-secondary text-foreground border-border";
    default:
      return "bg-primary/15 text-primary border-primary/30";
  }
}

/**
 * Resolved CSS color per format — used to paint the swatch on the Format
 * filter chips so the chip visually matches the session card's background.
 */
function formatSwatchColor(fmt: string): string {
  switch (fmt) {
    case "keynote": return "var(--color-accent, #ff8a9e)";
    case "lightning": return "var(--color-tertiary, #b8deff)";
    case "workshop": return "var(--color-secondary, #251c50)";
    default: return "var(--color-primary, #4985e8)";
  }
}

/**
 * Deterministic per-track accent color. Hashes the track name to a hue
 * in [0, 360) and returns the resolved HSL color so we don't have to put
 * var() inside a CSS color function (which esbuild 0.27 fails to parse).
 */
function trackColor(name: string): string | null {
  if (!name) return null;
  let h = 0;
  for (let i = 0; i < name.length; i++) {
    h = ((h << 5) - h + name.charCodeAt(i)) | 0;
  }
  const hue = Math.abs(h) % 360;
  return `hsl(${hue} 60% 62%)`;
}

const CSS_VARS = {
  "--grid-rows": String(GRID_ROWS),
  "--grid-cols": String(rooms.length),
} as Record<string, string>;
---

<div
  class="schedule-root"
  data-date={dayDateIso}
  data-schedule-format-keynote={t("schedule.format.keynote")}
  data-schedule-format-talk={t("schedule.format.talk")}
  data-schedule-format-lightning={t("schedule.format.lightning")}
  data-schedule-format-workshop={t("schedule.format.workshop")}
  data-schedule-agenda-remove={t("schedule.agenda.remove")}
  data-schedule-empty={t("schedule.agenda.empty")}
  style={`--grid-rows: ${GRID_ROWS}; --grid-cols: ${rooms.length};`}
>
  <!-- Filter bar — multi-select chips grouped by role, two rows -->
  <div class="sticky top-[64px] z-20 -mx-4 md:-mx-6 lg:-mx-8 px-4 md:px-6 lg:px-8 py-3 bg-background/90 backdrop-blur-sm border-b border-border">
    <div class="flex items-start justify-between gap-3">
      <div class="flex flex-col gap-3 flex-1 min-w-0" role="toolbar" aria-label={t("schedule.filter.toolbar")}>
        <!-- Room -->
        <div class="filter-group" role="group" aria-label={t("schedule.filter.all_rooms")}>
          <div class="chip-label">{t("schedule.filter.label_room")}</div>
          <div class="chip-stack">
            <button
              type="button"
              class="schedule-filter chip chip--all is-active"
              data-filter="room"
              data-value="__all__"
              aria-pressed="true"
            >
              {t("schedule.filter.all_rooms")}
            </button>
            {rooms.map((room) => (
              <button
                type="button"
                class="schedule-filter chip chip--room"
                data-filter="room"
                data-value={room}
                aria-pressed="false"
              >
                {room}
              </button>
            ))}
          </div>
        </div>

        <!-- Format -->
        <div class="filter-group" role="group" aria-label={t("schedule.filter.all_formats")}>
          <div class="chip-label">{t("schedule.filter.label_format")}</div>
          <div class="chip-stack">
            <button
              type="button"
              class="schedule-filter chip chip--all is-active"
              data-filter="format"
              data-value="__all__"
              aria-pressed="true"
            >
              {t("schedule.filter.all_formats")}
            </button>
            {formats.map((fmt) => (
              <button
                type="button"
                class="schedule-filter chip chip--format"
                data-filter="format"
                data-value={fmt}
                aria-pressed="false"
              >
                {t(`schedule.format.${fmt}` as any)}
              </button>
            ))}
          </div>
        </div>

        <!-- Track (collapses when no data classified yet) -->
        {tracks.length > 0 && (
          <div class="filter-group" role="group" aria-label={t("schedule.filter.all_tracks")}>
            <div class="chip-label">{t("schedule.filter.label_track")}</div>
            <div class="chip-stack">
              <button
                type="button"
                class="schedule-filter chip chip--all is-active"
                data-filter="track"
                data-value="__all__"
                aria-pressed="true"
              >
                {t("schedule.filter.all_tracks")}
              </button>
              {tracks.map((tr) => (
                <button
                  type="button"
                  class="schedule-filter chip chip--track chip--swatch"
                  data-filter="track"
                  data-value={tr}
                  aria-pressed="false"
                  style={"--swatch-color: " + (trackColor(tr) || "var(--color-muted-foreground)")}
                >
                  <span class="chip-swatch" aria-hidden="true"></span>
                  {tr}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Level (collapses when no data classified yet) -->
        {levels.length > 0 && (
          <div class="filter-group" role="group" aria-label={t("schedule.filter.all_levels")}>
            <div class="chip-label">{t("schedule.filter.label_level")}</div>
            <div class="chip-stack">
              <button
                type="button"
                class="schedule-filter chip chip--all is-active"
                data-filter="level"
                data-value="__all__"
                aria-pressed="true"
              >
                {t("schedule.filter.all_levels")}
              </button>
              {levels.map((lv) => (
                <button
                  type="button"
                  class="schedule-filter chip chip--level"
                  data-filter="level"
                  data-value={lv}
                  aria-pressed="false"
                >
                  {t(`schedule.level.${lv}` as any)}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Clear-all link appears when any filter is narrowed -->
        <div id="schedule-filter-clear-wrap" class="flex items-center gap-2" hidden>
          <button
            type="button"
            id="schedule-filter-clear"
            class="inline-flex items-center gap-1 text-xs text-muted-foreground hover:text-foreground underline underline-offset-2"
          >
            {t("schedule.filter.clear_all")}
          </button>
          <span id="schedule-filter-active-count" class="text-xs text-muted-foreground"></span>
        </div>
      </div>

      <!-- Right side: agenda + export actions -->
      <div class="flex items-center gap-2 shrink-0">
        <button
          type="button"
          id="schedule-agenda-toggle"
          class="inline-flex items-center gap-2 rounded-md border border-border bg-card px-3 h-9 text-sm font-medium text-foreground hover:border-primary/60"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg>
          <span>{t("schedule.agenda.label")}</span>
          <span id="schedule-agenda-count" class="rounded-full bg-primary/20 text-primary text-xs font-semibold px-2 py-0.5">0</span>
        </button>
        <button
          type="button"
          id="schedule-export-all"
          class="inline-flex items-center gap-2 rounded-md border border-primary/50 bg-transparent px-3 h-9 text-sm font-medium text-primary hover:bg-primary/10"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>
          <span class="hidden sm:inline">{t("schedule.export_all")}</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Grid -->
  <div class="schedule-grid mt-8">
    <!-- Room header row -->
    <div class="schedule-grid-headers">
      <div class="schedule-time-corner"></div>
      {rooms.map((room) => (
        <div class="schedule-room-header">
          <span class="text-sm font-bold uppercase tracking-wider">{room}</span>
        </div>
      ))}
    </div>

    <!-- Scrollable grid body -->
    <div class="schedule-grid-body">
      <!-- Time column -->
      <div class="schedule-time-col">
        {timeLabels.map(({ label, row }) => (
          <div class="schedule-time-label" style={`grid-row: ${row} / span 6;`}>
            {label}
          </div>
        ))}
      </div>

      <!-- Track cells grid -->
      <div class="schedule-tracks">
        <!-- Grid lines background -->
        {timeLabels.map(({ row }) => (
          <div class="schedule-gridline" style={`grid-row: ${row} / span 1; grid-column: 1 / -1;`}></div>
        ))}

        <!-- Session cards -->
        {sessions.map((s) => {
          const start = toMinutes(s.startTime);
          const startRow = (start - GRID_START) / 5 + 1;
          const span = Math.max(1, Math.round(s.durationMin / 5));
          const isKeynote = s.format === "keynote";
          const colStart = isKeynote
            ? 1
            : (rooms.indexOf(s.room) ?? 0) + 1;
          const colSpan = isKeynote ? rooms.length : 1;
          const style = `grid-row: ${startRow} / span ${span}; grid-column: ${colStart} / span ${colSpan};`;
          const speakers = sessionSpeakerLinks(s);
          const isCompact = s.durationMin <= 15;
          const trackCol = trackColor(s.track);
          const cardStyle = trackCol
            ? style + " border-left: 4px solid " + trackCol + ";"
            : style;
          return (
            <article
              class={`schedule-session ${isCompact ? "is-compact" : ""}`}
              style={cardStyle}
              data-session-id={s.id}
              data-room={s.room}
              data-format={s.format}
              data-track={s.track}
              data-level={s.level}
              data-title={s.title}
              data-start={s.startTime}
              data-duration={s.durationMin}
              data-description={s.description}
              data-feedback-url={s.feedbackUrl}
              data-slides-url={s.slidesUrl}
              data-recording-url={s.recordingUrl}
              data-cover-image={s.coverImageUrl}
              data-language={s.language}
              data-speakers={JSON.stringify(speakers)}
            >
              <div class="schedule-session-head">
                <span class="schedule-time-range">{formatTime(s.startTime)} — {endTime(s)}</span>
                <button
                  type="button"
                  class="schedule-bookmark"
                  aria-label={t("schedule.bookmark_toggle")}
                  data-bookmark={s.id}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg>
                </button>
              </div>
              <h3 class="schedule-session-title">{s.title}</h3>
              {speakers.length > 0 && (
                <p class="schedule-session-speakers">
                  {speakers.slice(0, 2).map((sp, i) => (
                    <>
                      {i > 0 && <span>, </span>}
                      {sp.href ? <a href={sp.href} class="hover:underline">{sp.label}</a> : <span>{sp.label}</span>}
                    </>
                  ))}
                  {speakers.length > 2 && <span> +{speakers.length - 2}</span>}
                </p>
              )}
            </article>
          );
        })}
      </div>
    </div>
  </div>
</div>

<!-- Session detail modal (hidden by default) -->
<div
  id="schedule-session-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4 md:p-6"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="schedule-session-modal-title"
>
  <div
    class="schedule-session-modal-backdrop absolute inset-0 bg-background/80 backdrop-blur-sm"
    data-close-modal
  ></div>
  <div class="relative max-w-2xl w-full max-h-[85vh] overflow-auto rounded-2xl border border-border bg-card shadow-2xl">
    <div class="flex items-start justify-between gap-3 px-6 pt-6 pb-4 border-b border-border/70">
      <div class="flex flex-wrap items-center gap-2" id="schedule-session-modal-meta-top">
        <!-- filled by JS: format chip, time pill, room pill, level pill -->
      </div>
      <button
        type="button"
        data-close-modal
        class="rounded-md w-9 h-9 inline-flex items-center justify-center text-muted-foreground hover:bg-muted hover:text-foreground"
        aria-label={t("schedule.close")}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
      </button>
    </div>
    <img
      id="schedule-session-modal-cover"
      alt=""
      class="hidden w-full aspect-[16/7] object-cover border-b border-border/70"
    />
    <div class="px-6 py-5 space-y-5">
      <h2 id="schedule-session-modal-title" class="text-2xl md:text-3xl font-bold text-foreground leading-tight" style="letter-spacing:-0.02em;"></h2>
      <div id="schedule-session-modal-speakers" class="flex flex-wrap gap-2 text-sm"></div>
      <div id="schedule-session-modal-tags" class="flex flex-wrap gap-2"></div>
      <div id="schedule-session-modal-description" class="text-base leading-relaxed" style="color: var(--color-foreground);"></div>
      <div id="schedule-session-modal-actions" class="flex flex-wrap items-center gap-2 pt-2">
        <button
          type="button"
          id="schedule-session-modal-bookmark"
          class="inline-flex items-center gap-2 rounded-md border border-border bg-background/60 px-3 h-9 text-sm font-medium text-foreground hover:border-primary/60"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg>
          <span data-bookmark-label>{t("schedule.bookmark_toggle")}</span>
        </button>
        <a
          id="schedule-session-modal-feedback"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md border border-primary/50 bg-transparent px-3 h-9 text-sm font-medium text-primary hover:bg-primary/10 hidden"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          {t("schedule.open_feedback")}
        </a>
        <a
          id="schedule-session-modal-slides"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md border border-border bg-background/60 px-3 h-9 text-sm font-medium text-foreground hover:border-primary/60 hidden"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 18v3"/></svg>
          {t("schedule.open_slides")}
        </a>
        <a
          id="schedule-session-modal-recording"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md border border-border bg-background/60 px-3 h-9 text-sm font-medium text-foreground hover:border-primary/60 hidden"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
          {t("schedule.open_recording")}
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Agenda drawer (hidden by default) -->
<aside
  id="schedule-agenda-drawer"
  class="fixed right-0 top-0 bottom-0 w-full sm:w-96 max-w-full bg-card border-l border-border z-50 shadow-2xl translate-x-full transition-transform duration-200"
  aria-hidden="true"
  role="dialog"
  aria-label={t("schedule.agenda.label")}
>
  <div class="flex items-center justify-between px-5 py-4 border-b border-border">
    <h2 class="text-lg font-bold">{t("schedule.agenda.title")}</h2>
    <button type="button" id="schedule-agenda-close" class="rounded-md w-9 h-9 inline-flex items-center justify-center hover:bg-muted" aria-label={t("schedule.close")}>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
    </button>
  </div>
  <div id="schedule-agenda-list" class="flex-1 overflow-auto p-4 space-y-2">
    <p class="text-sm text-muted-foreground">{t("schedule.agenda.empty")}</p>
  </div>
  <div class="p-4 border-t border-border">
    <button type="button" id="schedule-export-agenda" class="w-full inline-flex items-center justify-center gap-2 rounded-md bg-primary text-primary-foreground px-4 h-10 text-sm font-semibold hover:opacity-90">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>
      {t("schedule.export_agenda")}
    </button>
  </div>
</aside>

<style>
  .schedule-root { --row-height: 22px; --card-pad: 8px; }

  .chip {
    display: inline-flex;
    align-items: center;
    padding: 5px 11px;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    background-color: var(--color-card);
    color: var(--color-muted-foreground);
    font-size: 12.5px;
    font-weight: 500;
    transition: color 120ms, background 120ms, border-color 120ms;
    cursor: pointer;
    white-space: nowrap;
  }
  .chip:hover { color: var(--color-foreground); }
  .chip.is-active {
    background-color: color-mix(in oklch, var(--color-primary) 20%, transparent);
    color: var(--color-primary);
    border-color: color-mix(in oklch, var(--color-primary) 40%, transparent);
  }
  .chip--all.is-active {
    background-color: color-mix(in oklch, var(--color-foreground) 8%, transparent);
    color: var(--color-foreground);
    border-color: color-mix(in oklch, var(--color-foreground) 20%, transparent);
  }
  .chip-label {
    font-size: 10.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted-foreground);
    flex-shrink: 0;
  }
  .filter-group {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 12px;
    align-items: start;
  }
  .filter-group .chip-label {
    padding-top: 7px; /* visually aligns with chip text baseline */
  }
  .chip-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .chip-swatch {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background-color: var(--swatch-color, var(--color-muted-foreground));
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.2);
  }
  .chip--swatch {
    gap: 6px;
  }
  @media (max-width: 640px) {
    .filter-group { grid-template-columns: 1fr; gap: 4px; }
    .filter-group .chip-label { padding-top: 0; }
  }

  .schedule-grid-headers {
    position: sticky;
    top: calc(64px + 56px);
    z-index: 10;
    display: grid;
    grid-template-columns: 80px repeat(var(--grid-cols), minmax(160px, 1fr));
    gap: 4px;
    padding: 8px 0;
    background: color-mix(in oklch, var(--color-background) 92%, transparent);
    backdrop-filter: blur(6px);
  }
  .schedule-room-header {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 8px 12px;
    text-align: center;
    color: var(--color-foreground);
  }
  .schedule-time-corner { /* empty corner above time labels */ }

  .schedule-grid-body {
    display: grid;
    grid-template-columns: 80px 1fr;
    overflow-x: auto;
  }
  .schedule-time-col {
    display: grid;
    grid-template-rows: repeat(var(--grid-rows), var(--row-height));
    border-right: 1px dashed color-mix(in oklch, var(--color-border) 80%, transparent);
  }
  .schedule-time-label {
    font-size: 12px;
    color: var(--color-muted-foreground);
    padding-top: 2px;
    padding-right: 8px;
    text-align: right;
  }
  .schedule-tracks {
    position: relative;
    display: grid;
    grid-template-columns: repeat(var(--grid-cols), minmax(160px, 1fr));
    grid-template-rows: repeat(var(--grid-rows), var(--row-height));
    gap: 4px;
    padding-left: 4px;
  }
  .schedule-gridline {
    grid-row-start: attr(style);
    border-top: 1px dashed color-mix(in oklch, var(--color-border) 80%, transparent);
    pointer-events: none;
    height: 1px;
    margin-top: 0;
  }
  .schedule-session {
    border-radius: 8px;
    border: 1px solid;
    padding: var(--card-pad) calc(var(--card-pad) + 2px);
    background-color: var(--color-card);
    color: var(--color-foreground);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 4px;
    transition: border-color 150ms, transform 150ms;
    cursor: pointer;
    position: relative;
    z-index: 2;
  }
  .schedule-session:hover {
    border-color: color-mix(in oklch, var(--color-primary) 60%, transparent);
    transform: translateY(-1px);
  }
  .schedule-session-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .schedule-time-range {
    font-size: 11px;
    color: var(--color-muted-foreground);
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .schedule-bookmark {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted-foreground);
    background: transparent;
    border: 0;
    cursor: pointer;
  }
  .schedule-bookmark:hover { color: var(--color-foreground); background: color-mix(in oklch, var(--color-foreground) 8%, transparent); }
  .schedule-bookmark.is-on { color: var(--color-primary); }
  .schedule-bookmark.is-on svg { fill: currentColor; }
  .schedule-session-title {
    font-size: 13px;
    font-weight: 700;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .schedule-session-speakers {
    font-size: 12px;
    color: var(--color-muted-foreground);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .schedule-session.is-hidden { display: none; }

  /* Compact variant for lightning / sub-15-min sessions: drop the metadata
     header, trim padding, keep only time + tight title so the card stays
     readable even in 2-row (10-min) height. */
  .schedule-session.is-compact {
    padding: 4px 8px;
    gap: 2px;
  }
  .schedule-session.is-compact .schedule-session-head {
    font-size: 10px;
  }
  .schedule-session.is-compact .schedule-time-range { font-size: 10px; }
  .schedule-session.is-compact .schedule-bookmark { width: 18px; height: 18px; }
  .schedule-session.is-compact .schedule-bookmark svg { width: 12px; height: 12px; }
  .schedule-session.is-compact .schedule-session-title {
    font-size: 12px;
    -webkit-line-clamp: 2;
    line-clamp: 2;
  }
  .schedule-session.is-compact .schedule-session-speakers {
    font-size: 11px;
    -webkit-line-clamp: 1;
    line-clamp: 1;
  }

  /* Modal description: markdown-rendered paragraphs + inline elements */
  #schedule-session-modal-description p + p { margin-top: 0.75em; }
  #schedule-session-modal-description strong { color: var(--color-foreground); font-weight: 700; }
  #schedule-session-modal-description em { font-style: italic; }
  #schedule-session-modal-description code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    background-color: color-mix(in oklch, var(--color-background) 60%, transparent);
    color: var(--color-foreground);
  }
  #schedule-session-modal-description a {
    color: var(--color-primary);
    text-decoration: none;
  }
  #schedule-session-modal-description a:hover { text-decoration: underline; }

  /* Modal bookmark button on-state */
  #schedule-session-modal-bookmark.is-on {
    color: var(--color-primary);
    border-color: color-mix(in oklch, var(--color-primary) 50%, transparent);
    background-color: color-mix(in oklch, var(--color-primary) 10%, transparent);
  }
  #schedule-session-modal-bookmark.is-on svg { fill: currentColor; }

  /* Mobile: single column list view */
  @media (max-width: 767px) {
    .schedule-grid-headers,
    .schedule-grid-body > .schedule-time-col { display: none; }
    .schedule-grid-body { grid-template-columns: 1fr; }
    .schedule-tracks {
      display: flex;
      flex-direction: column;
      grid-template-rows: none;
      gap: 8px;
    }
    .schedule-gridline { display: none; }
    .schedule-session {
      grid-row: auto !important;
      grid-column: auto !important;
      border-left-width: 3px;
    }
    .schedule-session::before {
      content: attr(data-room);
      display: inline-block;
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-muted-foreground);
      margin-bottom: 4px;
    }
  }
</style>

<script is:inline define:vars={{}}>
  (() => {
    const root = document.querySelector(".schedule-root");
    if (!root) return;

    const STORAGE_KEY = "cnd-agenda-bookmarks-v1";
    const getBookmarks = () => {
      try {
        return new Set(JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]"));
      } catch {
        return new Set();
      }
    };
    const setBookmarks = (set) => {
      localStorage.setItem(STORAGE_KEY, JSON.stringify([...set]));
    };

    const bookmarks = getBookmarks();
    const countEl = document.getElementById("schedule-agenda-count");
    const updateCount = () => {
      if (countEl) countEl.textContent = String(bookmarks.size);
    };
    updateCount();

    // Apply initial state + hook bookmark buttons
    document.querySelectorAll("[data-bookmark]").forEach((btn) => {
      const id = btn.getAttribute("data-bookmark");
      if (id && bookmarks.has(id)) btn.classList.add("is-on");
      btn.addEventListener("click", (ev) => {
        ev.stopPropagation();
        if (!id) return;
        if (bookmarks.has(id)) {
          bookmarks.delete(id);
          btn.classList.remove("is-on");
        } else {
          bookmarks.add(id);
          btn.classList.add("is-on");
        }
        setBookmarks(bookmarks);
        updateCount();
        refreshAgenda();
      });
    });

    // Filters — multi-select per group. State: Map<groupName, Set<value>>.
    // An empty set means "all" for that group. Click a chip to add/remove from
    // the set. Click the "All X" chip to clear that group.
    // Keynotes always bypass the room filter (they span all rooms).
    const filterState = {
      room: new Set(),
      format: new Set(),
      track: new Set(),
      level: new Set(),
    };

    const clearWrap = document.getElementById("schedule-filter-clear-wrap");
    const activeCountEl = document.getElementById("schedule-filter-active-count");
    const labelHost = document.querySelector("[data-schedule-active-singular]");
    const activeCountLabelSingular = labelHost?.getAttribute("data-schedule-active-singular") || "filtre actif";
    const activeCountLabelPlural = labelHost?.getAttribute("data-schedule-active-plural") || "filtres actifs";

    const applyFilters = () => {
      document.querySelectorAll(".schedule-session").forEach((card) => {
        const room = card.getAttribute("data-room") || "";
        const format = card.getAttribute("data-format") || "";
        const track = card.getAttribute("data-track") || "";
        const level = card.getAttribute("data-level") || "";
        const roomOk = filterState.room.size === 0 || filterState.room.has(room) || format === "keynote";
        const formatOk = filterState.format.size === 0 || filterState.format.has(format);
        const trackOk = filterState.track.size === 0 || filterState.track.has(track);
        const levelOk = filterState.level.size === 0 || filterState.level.has(level);
        card.classList.toggle("is-hidden", !(roomOk && formatOk && trackOk && levelOk));
      });
      // Update each chip's is-active + aria-pressed
      document.querySelectorAll(".schedule-filter").forEach((btn) => {
        const f = btn.getAttribute("data-filter");
        const v = btn.getAttribute("data-value");
        if (!f || !v) return;
        const set = filterState[f];
        const active = v === "__all__" ? set.size === 0 : set.has(v);
        btn.classList.toggle("is-active", active);
        btn.setAttribute("aria-pressed", active ? "true" : "false");
      });
      // Clear-all visibility
      const total = filterState.room.size + filterState.format.size + filterState.track.size + filterState.level.size;
      if (clearWrap) {
        if (total > 0) clearWrap.removeAttribute("hidden");
        else clearWrap.setAttribute("hidden", "");
      }
      if (activeCountEl) {
        activeCountEl.textContent = total === 0
          ? ""
          : `(${total} ${total === 1 ? activeCountLabelSingular : activeCountLabelPlural})`;
      }
    };

    document.querySelectorAll(".schedule-filter").forEach((btn) => {
      btn.addEventListener("click", () => {
        const f = btn.getAttribute("data-filter");
        const v = btn.getAttribute("data-value");
        if (!f || !v) return;
        const set = filterState[f];
        if (v === "__all__") {
          set.clear();
        } else {
          if (set.has(v)) set.delete(v);
          else set.add(v);
        }
        applyFilters();
      });
    });

    document.getElementById("schedule-filter-clear")?.addEventListener("click", () => {
      filterState.room.clear();
      filterState.format.clear();
      filterState.track.clear();
      filterState.level.clear();
      applyFilters();
    });

    applyFilters();

    /**
     * Minimal Markdown → HTML renderer for the session description.
     * - HTML-escapes first so admin-authored content can't inject tags.
     * - Supports **bold**, __bold__, *italic*, _italic_, `code`, [text](url),
     *   paragraphs (blank line), and single newlines (<br>).
     * - Links must start with http(s):// or / to render — prevents javascript:
     *   or data: URIs from being rewritten into <a href>.
     */
    function mdToHtml(src) {
      const esc = (x) => String(x)
        .replace(/&/g, "&amp;").replace(/</g, "&lt;")
        .replace(/>/g, "&gt;").replace(/"/g, "&quot;");
      let h = esc(src);
      h = h.replace(/`([^`\n]+)`/g, '<code class="rounded bg-background/60 px-1 py-0.5 text-[0.95em]">$1</code>');
      h = h.replace(/\*\*([^*\n]+)\*\*/g, "<strong>$1</strong>");
      h = h.replace(/__([^_\n]+)__/g, "<strong>$1</strong>");
      h = h.replace(/(^|[^*])\*([^*\n]+)\*(?!\*)/g, "$1<em>$2</em>");
      h = h.replace(/(^|[^_])_([^_\n]+)_(?!_)/g, "$1<em>$2</em>");
      h = h.replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, (_m, t, u) => {
        if (!/^(https?:\/\/|\/)/.test(u)) return `[${t}](${u})`;
        return `<a href="${u}" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">${t}</a>`;
      });
      return h.split(/\n{2,}/).map((p) => `<p>${p.replace(/\n/g, "<br>")}</p>`).join("");
    }

    // Session detail modal
    const modal = document.getElementById("schedule-session-modal");
    const modalTitle = document.getElementById("schedule-session-modal-title");
    const modalMetaTop = document.getElementById("schedule-session-modal-meta-top");
    const modalSpeakers = document.getElementById("schedule-session-modal-speakers");
    const modalTags = document.getElementById("schedule-session-modal-tags");
    const modalDescription = document.getElementById("schedule-session-modal-description");
    const modalBookmarkBtn = document.getElementById("schedule-session-modal-bookmark");
    const modalFeedback = document.getElementById("schedule-session-modal-feedback");
    const modalSlides = document.getElementById("schedule-session-modal-slides");
    const modalRecording = document.getElementById("schedule-session-modal-recording");
    const modalCover = document.getElementById("schedule-session-modal-cover");
    let modalSessionId = null;

    const formatPalette = {
      keynote:   { label: root?.getAttribute("data-schedule-format-keynote")   || "Keynote",   cls: "bg-accent/15 text-accent" },
      talk:      { label: root?.getAttribute("data-schedule-format-talk")      || "Talk",      cls: "bg-primary/15 text-primary" },
      lightning: { label: root?.getAttribute("data-schedule-format-lightning") || "Lightning", cls: "bg-[color:var(--color-tertiary)]/15 text-[color:var(--color-tertiary)]" },
      workshop:  { label: root?.getAttribute("data-schedule-format-workshop")  || "Workshop",  cls: "bg-secondary text-foreground" },
    };
    const agendaRemoveLabel = root?.getAttribute("data-schedule-agenda-remove") || "Remove";

    function openModal(card) {
      if (!modal) return;
      const id = card.getAttribute("data-session-id") || "";
      const title = card.getAttribute("data-title") || "";
      const format = card.getAttribute("data-format") || "talk";
      const start = card.getAttribute("data-start") || "";
      const duration = Number(card.getAttribute("data-duration") || 0);
      const room = card.getAttribute("data-room") || "";
      const track = card.getAttribute("data-track") || "";
      const level = card.getAttribute("data-level") || "";
      const description = card.getAttribute("data-description") || "";
      const feedbackUrl = card.getAttribute("data-feedback-url") || "";
      const slidesUrl = card.getAttribute("data-slides-url") || "";
      const recordingUrl = card.getAttribute("data-recording-url") || "";
      const coverImage = card.getAttribute("data-cover-image") || "";
      const language = card.getAttribute("data-language") || "";
      let speakers = [];
      try { speakers = JSON.parse(card.getAttribute("data-speakers") || "[]"); } catch {}

      modalSessionId = id;
      if (modalTitle) modalTitle.textContent = title;

      // Top meta row: format chip + time + room + track + level
      if (modalMetaTop) {
        const fmt = formatPalette[format] || formatPalette.talk;
        const startHm = start.slice(11, 16);
        const [sH, sM] = startHm.split(":").map(Number);
        const endTotal = sH * 60 + sM + duration;
        const endHm = String(Math.floor(endTotal / 60) % 24).padStart(2, "0") + ":" + String(endTotal % 60).padStart(2, "0");
        const timeRange = startHm + " — " + endHm;
        const parts = [];
        parts.push(`<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold tracking-widest uppercase ${fmt.cls}">${fmt.label}</span>`);
        parts.push(`<span class="inline-flex items-center rounded-full bg-background/40 border border-border px-2.5 py-0.5 text-xs text-foreground">${timeRange} · ${duration} min</span>`);
        if (room) parts.push(`<span class="inline-flex items-center rounded-full bg-background/40 border border-border px-2.5 py-0.5 text-xs text-foreground">${room}</span>`);
        if (track) parts.push(`<span class="inline-flex items-center rounded-full bg-background/40 border border-border px-2.5 py-0.5 text-xs text-foreground">${track}</span>`);
        if (level) parts.push(`<span class="inline-flex items-center rounded-full bg-background/40 border border-border px-2.5 py-0.5 text-xs text-muted-foreground uppercase tracking-widest">${level}</span>`);
        if (language) parts.push(`<span class="inline-flex items-center rounded-full bg-background/40 border border-border px-2.5 py-0.5 text-xs text-muted-foreground uppercase tracking-widest">${language}</span>`);
        modalMetaTop.innerHTML = parts.join("");
      }

      // Cover image — optional hero at the top of the modal
      if (modalCover) {
        if (coverImage) {
          modalCover.setAttribute("src", coverImage);
          modalCover.setAttribute("alt", title);
          modalCover.style.display = "";
          modalCover.classList.remove("hidden");
        } else {
          modalCover.style.display = "none";
          modalCover.removeAttribute("src");
        }
      }

      // Speakers — render as clickable pills when we have a href, else plain pills
      if (modalSpeakers) {
        modalSpeakers.innerHTML = speakers.length === 0 ? "" : speakers.map((sp) => {
          const safeLabel = String(sp.label || "").replace(/</g, "&lt;");
          const cls = "inline-flex items-center gap-2 rounded-full border border-border bg-background/40 px-3 py-1 text-sm text-foreground hover:border-primary/60";
          return sp.href
            ? `<a href="${sp.href}" class="${cls} text-primary">${safeLabel} <span aria-hidden="true">→</span></a>`
            : `<span class="${cls} text-muted-foreground">${safeLabel}</span>`;
        }).join("");
      }

      // Tags (not in data-* currently — skip)
      if (modalTags) modalTags.innerHTML = "";

      // Description — render Markdown → safe HTML (admins edit in Sheets; escape first).
      if (modalDescription) {
        modalDescription.innerHTML = description ? mdToHtml(description) : "";
        modalDescription.classList.toggle("hidden", !description);
      }

      // Bookmark toggle reflects current state
      if (modalBookmarkBtn) {
        modalBookmarkBtn.classList.toggle("is-on", bookmarks.has(id));
      }

      // Use inline style.display toggles — Tailwind's .hidden utility
      // can lose to .inline-flex depending on CSS source order.
      const toggleLink = (el, url) => {
        if (!el) return;
        if (url) {
          el.setAttribute("href", url);
          el.style.display = "";
          el.classList.remove("hidden");
        } else {
          el.style.display = "none";
        }
      };
      toggleLink(modalFeedback, feedbackUrl);
      toggleLink(modalSlides, slidesUrl);
      toggleLink(modalRecording, recordingUrl);

      modal.classList.remove("hidden");
      modal.classList.add("flex");
      modal.setAttribute("aria-hidden", "false");
      document.body.classList.add("overflow-hidden");
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      modal.setAttribute("aria-hidden", "true");
      document.body.classList.remove("overflow-hidden");
      modalSessionId = null;
    }

    // Open modal on card click (but not when clicking the inline bookmark icon)
    document.querySelectorAll(".schedule-session").forEach((card) => {
      card.addEventListener("click", (ev) => {
        const target = ev.target;
        if (target instanceof Element) {
          if (target.closest("[data-bookmark]")) return;
          if (target.closest("a")) return;
        }
        openModal(card);
      });
      card.setAttribute("tabindex", "0");
      card.setAttribute("role", "button");
      card.addEventListener("keydown", (ev) => {
        if (ev.key === "Enter" || ev.key === " ") {
          ev.preventDefault();
          openModal(card);
        }
      });
    });

    // Close on backdrop / X click, Escape key
    modal?.querySelectorAll("[data-close-modal]").forEach((el) => {
      el.addEventListener("click", closeModal);
    });
    document.addEventListener("keydown", (ev) => {
      if (ev.key === "Escape" && modal && !modal.classList.contains("hidden")) closeModal();
    });

    // Auto-open a session modal when the URL hash matches #session-{id}
    // (deep-links from the /speakers/{slug} page "Ses talks" cards)
    function openFromHash() {
      const hash = window.location.hash || "";
      const m = hash.match(/^#session-([^/?&#]+)/);
      if (!m) return;
      const id = decodeURIComponent(m[1]);
      const card = document.querySelector(`.schedule-session[data-session-id="${CSS.escape(id)}"]`);
      if (card) {
        // Scroll the card into view first so the page is anchored correctly when modal closes
        card.scrollIntoView({ block: "center", behavior: "instant" });
        openModal(card);
      }
    }
    // Run on initial load and when hash changes (in-page navigation)
    if (window.location.hash.startsWith("#session-")) {
      // Defer so the rest of this script finishes wiring first
      setTimeout(openFromHash, 0);
    }
    window.addEventListener("hashchange", openFromHash);

    // Bookmark button inside modal
    modalBookmarkBtn?.addEventListener("click", () => {
      if (!modalSessionId) return;
      const id = modalSessionId;
      if (bookmarks.has(id)) {
        bookmarks.delete(id);
        modalBookmarkBtn.classList.remove("is-on");
      } else {
        bookmarks.add(id);
        modalBookmarkBtn.classList.add("is-on");
      }
      setBookmarks(bookmarks);
      updateCount();
      // Sync the inline bookmark too
      const inline = document.querySelector(`[data-bookmark="${id}"]`);
      inline?.classList.toggle("is-on", bookmarks.has(id));
      refreshAgenda();
    });

    // Agenda drawer
    const drawer = document.getElementById("schedule-agenda-drawer");
    const agendaList = document.getElementById("schedule-agenda-list");
    const emptyLabel = root?.getAttribute("data-schedule-empty") || "";
    const openDrawer = () => {
      if (!drawer) return;
      drawer.classList.remove("translate-x-full");
      drawer.setAttribute("aria-hidden", "false");
    };
    const closeDrawer = () => {
      if (!drawer) return;
      drawer.classList.add("translate-x-full");
      drawer.setAttribute("aria-hidden", "true");
    };
    document.getElementById("schedule-agenda-toggle")?.addEventListener("click", () => {
      refreshAgenda();
      openDrawer();
    });
    document.getElementById("schedule-agenda-close")?.addEventListener("click", closeDrawer);

    function refreshAgenda() {
      if (!agendaList) return;
      agendaList.innerHTML = "";
      if (bookmarks.size === 0) {
        const p = document.createElement("p");
        p.className = "text-sm text-muted-foreground";
        p.textContent = emptyLabel;
        agendaList.appendChild(p);
        return;
      }
      const picked = [];
      bookmarks.forEach((id) => {
        const card = document.querySelector(`.schedule-session[data-session-id="${id}"]`);
        if (card) picked.push(card);
      });
      picked.sort((a, b) => (a.getAttribute("data-start") || "").localeCompare(b.getAttribute("data-start") || ""));
      picked.forEach((card) => {
        const id = card.getAttribute("data-session-id");
        const title = card.getAttribute("data-title") || "";
        const start = card.getAttribute("data-start") || "";
        const timeLabel = start.slice(11, 16);
        const room = card.getAttribute("data-room") || "";
        const item = document.createElement("div");
        item.className = "flex items-start justify-between gap-3 rounded-md border border-border bg-background/40 p-3";
        item.innerHTML = `
          <div class="min-w-0">
            <div class="text-xs text-muted-foreground">${timeLabel} · ${room}</div>
            <div class="text-sm font-semibold text-foreground truncate">${title}</div>
          </div>
          <button type="button" class="agenda-remove shrink-0 text-muted-foreground hover:text-foreground" aria-label="${agendaRemoveLabel}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
          </button>
        `;
        item.querySelector(".agenda-remove")?.addEventListener("click", () => {
          if (!id) return;
          bookmarks.delete(id);
          setBookmarks(bookmarks);
          updateCount();
          const trigger = document.querySelector(`[data-bookmark="${id}"]`);
          trigger?.classList.remove("is-on");
          refreshAgenda();
        });
        agendaList.appendChild(item);
      });
    }

    // iCal export
    function pad(n) { return String(n).padStart(2, "0"); }
    function icsDate(iso) {
      const d = new Date(iso);
      return `${d.getUTCFullYear()}${pad(d.getUTCMonth() + 1)}${pad(d.getUTCDate())}T${pad(d.getUTCHours())}${pad(d.getUTCMinutes())}${pad(d.getUTCSeconds())}Z`;
    }
    function icsEscape(s) {
      return String(s).replace(/\\/g, "\\\\").replace(/;/g, "\\;").replace(/,/g, "\\,").replace(/\r?\n/g, "\\n");
    }
    function buildIcs(ids) {
      const events = [];
      ids.forEach((id) => {
        const card = document.querySelector(`.schedule-session[data-session-id="${id}"]`);
        if (!card) return;
        const start = card.getAttribute("data-start") || "";
        const duration = Number(card.getAttribute("data-duration") || 0);
        const end = new Date(new Date(start).getTime() + duration * 60000).toISOString();
        const title = card.getAttribute("data-title") || "";
        const room = card.getAttribute("data-room") || "";
        events.push([
          "BEGIN:VEVENT",
          `UID:${id}@cloudnativedays.fr`,
          `DTSTAMP:${icsDate(new Date().toISOString())}`,
          `DTSTART:${icsDate(start)}`,
          `DTEND:${icsDate(end)}`,
          `SUMMARY:${icsEscape(title)}`,
          `LOCATION:${icsEscape(room + " / CENTQUATRE-PARIS")}`,
          "END:VEVENT",
        ].join("\r\n"));
      });
      return [
        "BEGIN:VCALENDAR",
        "VERSION:2.0",
        "PRODID:-//Cloud Native Days France 2027//Schedule//FR",
        "CALSCALE:GREGORIAN",
        "METHOD:PUBLISH",
        ...events,
        "END:VCALENDAR",
      ].join("\r\n");
    }
    function download(filename, contents) {
      const blob = new Blob([contents], { type: "text/calendar;charset=utf-8" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    }

    document.getElementById("schedule-export-all")?.addEventListener("click", () => {
      // Link straight to the static /programme.ics build endpoint
      window.location.href = "/programme.ics";
    });
    document.getElementById("schedule-export-agenda")?.addEventListener("click", () => {
      if (bookmarks.size === 0) return;
      download("cnd-france-2027-agenda.ics", buildIcs([...bookmarks]));
    });
  })();
</script>
